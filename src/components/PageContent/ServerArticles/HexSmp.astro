---
import NavBar from '../../NavBar/NavBar.astro'
import Footer from '../../Footer/Footer.astro'
import ContentContainer from '../../ContentContainer/ContentContainer.astro'
import FullImageContainer from '../../FullImageContainer/FullImageContainer.astro'
import '../../NavBar/NavBar.css'
import '../WelcomePage/Welcome.styles.css'
import Section from '../../ContentContainer/Section.astro'
import FAQ from '../../FAQ/FAQ.astro'
import FAQLine from '../../FAQ/FAQLine.astro'
import FAQQuestion from '../../FAQ/FAQQuestion.astro'
import FAQAnswer from '../../FAQ/FAQAnswer.astro'
import Breadcrumbs from '../../Breadcrumbs/Breadcrumbs.astro'

const base = import.meta.env.BASE_URL;
---

<NavBar/>
<ContentContainer style="background-color: #0a0d12; color: #e0d8cc;">
    <Breadcrumbs items={[{ label: "HEX SMP" }]} />

    <!-- ===== HERO ===== -->
    <FullImageContainer imagePath="images/construction.jpeg" imageLink="#" wrapperClass="blackBackground smpHeroBanner" imageClass="otherAspect" wrapperStyle="height: 440px;" altText="HEX SMP - nowy tryb Minecraft w produkcji">
        <div class="smpHeroOverlay"></div>
        <div class="smpHeroContent">
            <span class="smpHeroBadge">⚔️ HEX SMP</span>
            <span class="smpStatusPill"><span class="smpPulse"></span> W PRODUKCJI</span>
            <h1 class="smpHeroTitle">Twój świat. Twoje zasady. Twoi rywale.</h1>
            <p class="smpHeroSub">Nowy tryb Minecraft SMP, w którym to co zbudujesz naprawdę ma znaczenie.<br/>Śledź produkcję — i bądź pierwszy, gdy serwer wystartuje.</p>
            <div class="smpHeroCta">
                <a class="smpBtn smpBtnPrimary" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer">Dołącz na Discord</a>
                <a class="smpBtn smpBtnGhost smpCopyIp" href="#" data-copy-ip="MinecraftHEX.pl" aria-label="Skopiuj adres IP serwera">Skopiuj IP: MinecraftHEX.pl</a>
            </div>
        </div>
    </FullImageContainer>

    <Section>
        <div class="smp">

            <!-- ===== HOOK: NIE KOLEJNY SMP ===== -->
            <section class="smpHook reveal">
                <span class="smpSectionLabel" aria-hidden="true">// INTRO</span>
                <h2 class="smpSectionTitle">Nie kolejny SMP.</h2>
                <div class="smpHookText">
                    <p>Znasz to uczucie — wchodzisz na serwer, budujesz bazę, po tygodniu jest nudno.</p>
                    <p><strong>HEX SMP to coś innego.</strong></p>
                    <p>Tutaj Twoja baza to nie tylko bloki — to Twoja ekonomia, Twoja siła, Twój cel. Inni gracze nie są tłem — są zagrożeniem i szansą jednocześnie. A system gry sprawia, że <strong>codziennie masz powód, żeby wrócić</strong>.</p>
                    <p>Nie ma tu przypadkowych mechanik. Każdy element jest zaprojektowany żebyś chciał grać — nie dlatego że musisz, ale dlatego że nie możesz się oderwać.</p>
                </div>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== FEATURE CARDS ===== -->
            <section class="smpFeatures reveal">
                <span class="smpSectionLabel" aria-hidden="true">// FEATURES</span>
                <h2 class="smpSectionTitle">Zaprojektowany, żebyś nie mógł przestać grać.</h2>
                <div class="smpFeatureGrid">
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:0">
                        <span class="smpFeatureIcon">🏗️</span>
                        <h3>Twoja baza, Twoja twierdza</h3>
                        <p>Budujesz nie dla ładnego wyglądu — budujesz, żeby przetrwać.</p>
                    </article>
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:1">
                        <span class="smpFeatureIcon">💰</span>
                        <h3>Ekonomia, która działa</h3>
                        <p>Twoje zasoby generują się automatycznie. Im lepiej zarządzasz, tym szybciej rośniesz.</p>
                    </article>
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:2">
                        <span class="smpFeatureIcon">⚔️</span>
                        <h3>PvP z prawdziwą stawką</h3>
                        <p>Vanilla combat, zero pay-to-win. Każda walka coś kosztuje — i coś daje.</p>
                    </article>
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:3">
                        <span class="smpFeatureIcon">🤝</span>
                        <h3>Inni gracze to nie tło</h3>
                        <p>Twoje decyzje wpływają na nich. Ich decyzje wpływają na Ciebie. Codziennie.</p>
                    </article>
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:4">
                        <span class="smpFeatureIcon">📅</span>
                        <h3>Powód żeby wracać</h3>
                        <p>System gry daje Ci coś do zrobienia każdego dnia. Zero pustych sesji.</p>
                    </article>
                    <article class="smpFeatureCard reveal-child" style="--reveal-i:5">
                        <span class="smpFeatureIcon">🔮</span>
                        <h3>To dopiero początek</h3>
                        <p>Nowe mechaniki będą się pojawiać po starcie. Bądź od początku — zanim reszta się połapie.</p>
                    </article>
                </div>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== QUIZ ===== -->
            <section class="smpQuiz reveal" id="smpQuiz">
                <span class="smpSectionLabel" aria-hidden="true">// QUIZ</span>
                <h2 class="smpSectionTitle">Twój styl gry. Twoja przewaga.</h2>
                <div class="quizContainer" id="quizContainer">
                    <!-- Q1 -->
                    <div class="quizScreen quizScreenActive" data-q="0">
                        <div class="quizQNum">Pytanie 1 z 5</div>
                        <p class="quizQText">Wchodzisz na serwer. Co robisz najpierw?</p>
                        <div class="quizOptions">
                            <button class="quizOption" data-type="budowniczy">🏗️ Szukam idealnego miejsca na bazę</button>
                            <button class="quizOption" data-type="wojownik">⚔️ Sprawdzam kto jest online</button>
                            <button class="quizOption" data-type="strateg">💰 Idę farmić surowce</button>
                            <button class="quizOption" data-type="dyplomata">🤝 Piszę na czacie "ktoś gra?"</button>
                        </div>
                    </div>
                    <!-- Q2 -->
                    <div class="quizScreen" data-q="1">
                        <div class="quizQNum">Pytanie 2 z 5</div>
                        <p class="quizQText">Ktoś atakuje Twojego znajomego. Co robisz?</p>
                        <div class="quizOptions">
                            <button class="quizOption" data-type="wojownik">⚔️ Lecę walczyć natychmiast</button>
                            <button class="quizOption" data-type="strateg">🧠 Najpierw sprawdzam sytuację, potem działam</button>
                            <button class="quizOption" data-type="budowniczy">🏗️ Buduję mu lepszą obronę na przyszłość</button>
                            <button class="quizOption" data-type="dyplomata">🤝 Negocjuję z atakującym</button>
                        </div>
                    </div>
                    <!-- Q3 -->
                    <div class="quizScreen" data-q="2">
                        <div class="quizQNum">Pytanie 3 z 5</div>
                        <p class="quizQText">Dostajesz rzadki item. Co z nim robisz?</p>
                        <div class="quizOptions">
                            <button class="quizOption" data-type="strateg">💰 Sprzedaję za max cenę</button>
                            <button class="quizOption" data-type="wojownik">⚔️ Używam w walce</button>
                            <button class="quizOption" data-type="budowniczy">🏗️ Włączam do projektu bazy</button>
                            <button class="quizOption" data-type="dyplomata">🤝 Daję komuś kto potrzebuje</button>
                        </div>
                    </div>
                    <!-- Q4 -->
                    <div class="quizScreen" data-q="3">
                        <div class="quizQNum">Pytanie 4 z 5</div>
                        <p class="quizQText">Co najbardziej Cię wkurza na serwerach?</p>
                        <div class="quizOptions">
                            <button class="quizOption" data-type="wojownik">💀 Że PvP jest niezbalansowane</button>
                            <button class="quizOption" data-type="strateg">😴 Że po tygodniu nie ma co robić</button>
                            <button class="quizOption" data-type="budowniczy">🏚️ Że bazy nic nie znaczą</button>
                            <button class="quizOption" data-type="dyplomata">👻 Że serwer jest martwy i nikt nie gada</button>
                        </div>
                    </div>
                    <!-- Q5 -->
                    <div class="quizScreen" data-q="4">
                        <div class="quizQNum">Pytanie 5 z 5</div>
                        <p class="quizQText">Jak chcesz żeby inni Cię zapamiętali na serwerze?</p>
                        <div class="quizOptions">
                            <button class="quizOption" data-type="wojownik">🏆 Jako top gracza, którego każdy zna</button>
                            <button class="quizOption" data-type="strateg">🧠 Jako tego, który kontrolował wszystko z cienia</button>
                            <button class="quizOption" data-type="budowniczy">🏗️ Jako twórcę najlepszej bazy na serwerze</button>
                            <button class="quizOption" data-type="dyplomata">🤝 Jako lidera największej grupy</button>
                        </div>
                    </div>
                    <!-- Result screen -->
                    <div class="quizResult" id="quizResult"></div>
                    <!-- Progress -->
                    <div class="quizProgressBar"><div class="quizProgressFill" id="quizProgressFill"></div></div>
                    <div class="quizProgressText" id="quizProgressText">0 / 5</div>
                </div>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== PILLARS: KAŻDY ELEMENT MA SENS ===== -->
            <section class="smpPillars reveal">
                <h2 class="smpSectionTitle">Każdy element ma sens.</h2>
                <div class="smpPillarList">
                    <div class="smpPillar reveal-child" style="--reveal-i:0">
                        <span class="smpPillarIcon">💰</span>
                        <div class="smpPillarBody">
                            <h3>Ekonomia, która działa sama</h3>
                            <p>Nie musisz siedzieć godzinami w kopalni. Twoje zasoby rosną nawet gdy jesteś offline. Ale… inni o tym wiedzą.</p>
                        </div>
                    </div>
                    <div class="smpPillar reveal-child" style="--reveal-i:1">
                        <span class="smpPillarIcon">⚔️</span>
                        <div class="smpPillarBody">
                            <h3>PvP z prawdziwą stawką</h3>
                            <p>Zero artefaktów za kasę, zero OP broni. Czysty skill. A każda walka ma konsekwencje — dla obydwu stron.</p>
                        </div>
                    </div>
                    <div class="smpPillar reveal-child" style="--reveal-i:2">
                        <span class="smpPillarIcon">📅</span>
                        <div class="smpPillarBody">
                            <h3>Codziennie coś nowego</h3>
                            <p>System gry nie pozwala Ci się nudzić. Każdego dnia masz nowy powód żeby wejść — i nowy powód żeby zostać dłużej.</p>
                        </div>
                    </div>
                    <div class="smpPillar reveal-child" style="--reveal-i:3">
                        <span class="smpPillarIcon">🔮</span>
                        <div class="smpPillarBody">
                            <h3>Tryb, który rośnie</h3>
                            <p>Na starcie dostaniesz bazę. Z czasem pojawią się mechaniki, które zmienią wszystko. Bądź od początku.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== FOMO CTA ===== -->
            <section class="smpFomo reveal">
                <h2 class="smpSectionTitle">Bądź pierwszy.</h2>
                <p class="smpFomoText">Serwer jest w produkcji. To znaczy, że ci co dołączą teraz — będą mieli przewagę.</p>
                <p class="smpFomoText">Śledź devlog. Bądź na Discordzie. Kiedy serwer ruszy — będziesz gotowy.</p>
                <a class="smpBtn smpBtnPrimary smpBtnWide" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer">Dołącz na Discord</a>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== DEVLOG PREVIEW ===== -->
            <section class="smpDevlogPreview reveal">
                <h2 class="smpSectionTitle">Co słychać w produkcji?</h2>
                <div class="smpDevlogList">
                    <article class="smpDevlogEntry reveal-child" style="--reveal-i:0">
                        <div class="smpDevlogMeta">
                            <time>10 kwi 2026</time>
                            <span class="smpDevlogTag" data-tag="mechanika">mechanika</span>
                        </div>
                        <h3>System ekonomii — pierwsze testy</h3>
                        <p>Automatyczne generowanie zasobów działa. Balansujemy tempo wzrostu.</p>
                    </article>
                    <article class="smpDevlogEntry reveal-child" style="--reveal-i:1">
                        <div class="smpDevlogMeta">
                            <time>28 mar 2026</time>
                            <span class="smpDevlogTag" data-tag="mapa">mapa</span>
                        </div>
                        <h3>Spawn i strefy startowe</h3>
                        <p>Nowy spawn w budowie. Strefy startowe zaprojektowane pod 4 kierunki.</p>
                    </article>
                    <article class="smpDevlogEntry reveal-child" style="--reveal-i:2">
                        <div class="smpDevlogMeta">
                            <time>15 mar 2026</time>
                            <span class="smpDevlogTag" data-tag="balans">balans</span>
                        </div>
                        <h3>PvP — vanilla combat testy</h3>
                        <p>Testy walki vanilla. Zero custom enchantów — czysty skill.</p>
                    </article>
                </div>
                <a class="smpDevlogLink" href={`${base}devlog`}>Zobacz cały devlog →</a>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== GALLERY ===== -->
            <section class="smpGallery reveal">
                <h2 class="smpSectionTitle">Zaglądasz za kurtynę.</h2>
                <p class="smpGallerySub">Widzisz to, czego inni jeszcze nie widzieli.</p>
                <div class="smpGalleryGrid">
                    <div class="smpGallerySlot smpGalleryMain">
                        <div class="smpVideoPlaceholder">
                            <span class="smpVideoIcon">▶</span>
                            <span>Film z procesu tworzenia — wkrótce</span>
                        </div>
                    </div>
                    <div class="smpGallerySlot">
                        <picture><source srcset={`${base}images/Archive/Hex6/1.webp`} type="image/webp" /><img src={`${base}images/Archive/Hex6/1.jpg`} alt="Budowa HEX SMP — zdjęcie 1" loading="lazy" decoding="async" /></picture>
                    </div>
                    <div class="smpGallerySlot">
                        <picture><source srcset={`${base}images/Archive/Hex6/2.webp`} type="image/webp" /><img src={`${base}images/Archive/Hex6/2.jpg`} alt="Budowa HEX SMP — zdjęcie 2" loading="lazy" decoding="async" /></picture>
                    </div>
                    <div class="smpGallerySlot">
                        <picture><source srcset={`${base}images/Archive/Hex6/3.webp`} type="image/webp" /><img src={`${base}images/Archive/Hex6/3.jpg`} alt="Budowa HEX SMP — zdjęcie 3" loading="lazy" decoding="async" /></picture>
                    </div>
                    <div class="smpGallerySlot smpGalleryPlaceholder">
                        <span>Więcej screenów wkrótce</span>
                    </div>
                    <div class="smpGallerySlot smpGalleryPlaceholder">
                        <span>Więcej screenów wkrótce</span>
                    </div>
                </div>
            </section>

            <!-- ===== DIVIDER ===== -->
            <div class="smpDivider" aria-hidden="true"></div>

            <!-- ===== FAQ ===== -->
            <section class="smpFaq reveal">
                <h2 class="smpSectionTitle">FAQ — HEX SMP</h2>
                <FAQ>
                    <FAQLine>
                        <FAQQuestion>Czym jest HEX SMP?</FAQQuestion>
                        <FAQAnswer>Nowy tryb Minecraft SMP łączący survival, ekonomię i PvP. Twoja baza, Twoje zasoby i Twoi rywale — wszystko połączone w jedną rozgrywkę.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Kiedy start serwera?</FAQQuestion>
                        <FAQAnswer>Tryb jest w produkcji. Datę ogłosimy na Discordzie — dołącz żeby być na bieżąco.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Co wyróżnia HEX SMP od innych serwerów?</FAQQuestion>
                        <FAQAnswer>System, w którym codziennie masz co robić. Ekonomia działa sama, PvP ma stawkę, a decyzje mają konsekwencje. Nie jest nudno.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Czy to pay-to-win?</FAQQuestion>
                        <FAQAnswer>Nie. PvP jest vanilla. Kasa nie kupuje przewagi.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Jak dołączyć?</FAQQuestion>
                        <FAQAnswer>Wejdź na Discorda HEX — tam zapisy, ogłoszenia i społeczność.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Gdzie śledzić postępy?</FAQQuestion>
                        <FAQAnswer>Devlog na stronie + Discord. Tam pierwszy dowiesz się co nowego.</FAQAnswer>
                    </FAQLine>
                </FAQ>
            </section>

            <!-- ===== FINAL CTA ===== -->
            <section class="smpFinalCta reveal">
                <h2 class="smpSectionTitle">Nie czekaj na start. Bądź przy starcie.</h2>
                <div class="smpFinalCtaRow">
                    <a class="smpBtn smpBtnPrimary" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer">Dołącz na Discord</a>
                    <a class="smpBtn smpBtnGhost" href={`${base}devlog`}>Zobacz devlog</a>
                </div>
            </section>

        </div>
    </Section>
</ContentContainer>
<Footer/>

<!-- ===== COPY IP ===== -->
<script>
    document.querySelectorAll<HTMLAnchorElement>('.smpCopyIp').forEach((button) => {
        button.addEventListener('click', async (event) => {
            event.preventDefault();
            const ip = button.dataset.copyIp || 'MinecraftHEX.pl';
            const defaultLabel = `Skopiuj IP: ${ip}`;
            let copied = false;
            try {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(ip);
                    copied = true;
                }
            } catch { copied = false; }
            if (!copied) {
                const t = document.createElement('textarea');
                t.value = ip; t.setAttribute('readonly', '');
                t.style.position = 'fixed'; t.style.opacity = '0';
                document.body.appendChild(t); t.select();
                try { copied = document.execCommand('copy'); } catch { copied = false; }
                document.body.removeChild(t);
            }
            button.textContent = copied ? `Skopiowano IP: ${ip}` : 'Nie udało się skopiować';
            button.classList.add(copied ? 'copied' : 'copyError');
            setTimeout(() => { button.textContent = defaultLabel; button.classList.remove('copied', 'copyError'); }, 1800);
        });
    });
</script>

<!-- ===== QUIZ LOGIC ===== -->
<script>
    const scores: Record<string, number> = { strateg: 0, wojownik: 0, budowniczy: 0, dyplomata: 0 };
    const totalQ = 5;
    let currentQ = 0;

    const typeData: Record<string, { icon: string; name: string; desc: string }> = {
        strateg: { icon: '🧠', name: 'STRATEG', desc: 'Nie wchodzisz do walki nieprzygotowany. Twoja baza jest fortecą, a ekonomia — maszyną. Na HEX SMP będziesz niebezpieczny.' },
        wojownik: { icon: '⚔️', name: 'WOJOWNIK', desc: 'PvP to Twój żywioł. Szukasz walki, ryzykujesz i zgarniasz nagrody. Na HEX SMP staniesz przed prawdziwym wyzwaniem.' },
        budowniczy: { icon: '🏗️', name: 'BUDOWNICZY', desc: 'Twoja baza to dzieło sztuki i twierdza w jednym. Na HEX SMP to co zbudujesz będzie miało realne znaczenie.' },
        dyplomata: { icon: '🤝', name: 'DYPLOMATA', desc: 'Wiesz, że siła to ludzie. Sojusze, handel, kontakty. Na HEX SMP Twoja sieć znajomości będzie Twoją bronią.' },
    };

    function updateProgress() {
        const fill = document.getElementById('quizProgressFill');
        const text = document.getElementById('quizProgressText');
        if (fill) fill.style.width = `${(currentQ / totalQ) * 100}%`;
        if (text) text.textContent = `${currentQ} / ${totalQ}`;
    }

    function showResult() {
        const priority = ['wojownik', 'strateg', 'budowniczy', 'dyplomata'] as const;
        let maxType = priority[0];
        let maxScore = scores[priority[0]];
        for (const t of priority) {
            if (scores[t] > maxScore) { maxScore = scores[t]; maxType = t; }
        }

        const data = typeData[maxType];
        const result = document.getElementById('quizResult');
        const progressBar = document.querySelector('.quizProgressBar') as HTMLElement;
        const progressText = document.getElementById('quizProgressText');
        if (progressBar) progressBar.style.display = 'none';
        if (progressText) progressText.style.display = 'none';

        if (result) {
            result.innerHTML = `
                <div class="quizResultIcon">${data.icon}</div>
                <div class="quizResultType">Twój typ: ${data.name}</div>
                <p class="quizResultDesc">${data.desc}</p>
                <a class="smpBtn smpBtnPrimary" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer">🔥 Dołącz na Discord — bądź pierwszy</a>
                <button class="quizShareBtn" id="quizShare">Twoi znajomi mogą być innym typem → Wyślij quiz</button>
            `;
            result.classList.add('quizResultActive');
            document.getElementById('quizShare')?.addEventListener('click', async () => {
                const url = window.location.origin + import.meta.env.BASE_URL + 'hexSmp#smpQuiz';
                if (navigator.share) {
                    try { await navigator.share({ title: 'Jaki typ gracza jesteś?', text: `Mój typ to ${data.name}! Sprawdź swój:`, url }); } catch {}
                } else {
                    try { await navigator.clipboard.writeText(url); } catch {}
                    const btn = document.getElementById('quizShare');
                    if (btn) { btn.textContent = 'Link skopiowany!'; setTimeout(() => { btn.textContent = 'Twoi znajomi mogą być innym typem → Wyślij quiz'; }, 2000); }
                }
            });
        }
    }

    document.querySelectorAll('.quizOption').forEach((btn) => {
        btn.addEventListener('click', () => {
            const type = (btn as HTMLElement).dataset.type;
            if (type && type in scores) scores[type]++;

            const currentScreen = document.querySelector(`.quizScreen[data-q="${currentQ}"]`);
            currentQ++;
            updateProgress();

            if (currentScreen) {
                currentScreen.classList.add('quizScreenExit');
                currentScreen.classList.remove('quizScreenActive');
            }

            setTimeout(() => {
                if (currentScreen) (currentScreen as HTMLElement).style.display = 'none';

                if (currentQ >= totalQ) {
                    showResult();
                } else {
                    const next = document.querySelector(`.quizScreen[data-q="${currentQ}"]`) as HTMLElement;
                    if (next) { next.style.display = 'flex'; next.classList.add('quizScreenActive'); } 
                }
            }, 300);
        });
    });

    updateProgress();
</script>

<!-- ===== SCROLL REVEAL ===== -->
<script>
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                revealObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
</script>

