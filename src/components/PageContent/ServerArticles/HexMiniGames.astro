---
import NavBar from '../../NavBar/NavBar.astro'
import Footer from '../../Footer/Footer.astro'
import ContentContainer from '../../ContentContainer/ContentContainer.astro'
import FullImageContainer from '../../FullImageContainer/FullImageContainer.astro'
import '../../NavBar/NavBar.css'
import '../WelcomePage/Welcome.styles.css'
import './ServerArticle.styles.css'
import TimeContainer from '../../DiscordContainer/TimeContainer.astro'
import Section from '../../ContentContainer/Section.astro'
import FAQ from '../../FAQ/FAQ.astro'
import FAQLine from '../../FAQ/FAQLine.astro'
import FAQQuestion from '../../FAQ/FAQQuestion.astro'
import FAQAnswer from '../../FAQ/FAQAnswer.astro'
import Breadcrumbs from '../../Breadcrumbs/Breadcrumbs.astro'
---

<NavBar/>
<ContentContainer>
    <Breadcrumbs items={[{ label: "Mini Games" }]} />
    <FullImageContainer imagePath="images/construction.jpeg" imageLink="#" wrapperClass="blackBackground construction" altText="Serwer Mini-Games Minecraft HEX - strona w przygotowaniu">
        <div style="width: 100%; height: 100%; display: flex; justify-content: center; align-items: center;">
            <h1 class="archiveBannerText"></h1>
        </div>
    </FullImageContainer>

    <div style="display: flex; width: 100%; justify-content: center;">
        <TimeContainer />
    </div>

    <Section>
        <article class="serverArticle">
            <header class="articleHeader">
                <p class="statusKicker">Status projektu</p>
                <h1>Serwer Mini-Games</h1>
                <p class="articleLead">Serwer Mini-Games jest w przygotowaniu. Trwają testy mini-gier, rankingów i map parkour pod rekordy czasu.</p>
            </header>

            <div class="articleColumns">
                <section>
                    <h2>Kierunek projektu</h2>
                    <p>Budujemy lekki, dynamiczny tryb nastawiony na krótsze sesje i zdrową rywalizację między graczami.</p>
                </section>

                <section>
                    <h2>Na starcie planujemy</h2>
                    <ul>
                        <li>Wybrane mini-gry i rotację map.</li>
                        <li>Tablice wyników i rankingi sezonowe.</li>
                        <li>System rekordów czasu dla tras parkour.</li>
                    </ul>
                </section>
            </div>

            <section class="faqSection">
                <h2>FAQ - Mini-Games</h2>
                <FAQ>
                    <FAQLine>
                        <FAQQuestion>Jakie mini-gry będą dostępne na starcie?</FAQQuestion>
                        <FAQAnswer>Na start planujemy rotację najpopularniejszych mini-gier oraz mapy parkour z tabelą rekordów.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Czy rankingi w Mini-Games będą sezonowe?</FAQQuestion>
                        <FAQAnswer>Tak, rankingi będą resetowane sezonowo, a najlepsze wyniki trafią do archiwum i podsumowań.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Gdzie śledzić aktualizacje map i trybów?</FAQQuestion>
                        <FAQAnswer>Aktualizacje publikujemy regularnie na stronie głównej oraz na Discordzie HEX.</FAQAnswer>
                    </FAQLine>
                </FAQ>
            </section>

            <p class="comingSoon">NIEBAWEM</p>
        </article>
    </Section>

</ContentContainer>
<Footer/>
