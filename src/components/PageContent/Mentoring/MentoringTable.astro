---
// Importowanie komponentu Table
import Table from '../../SimpleTable/SimpleTable.astro';

const base = import.meta.env.BASE_URL;

const headers = [
  'Szkolenie indywidualne', 
  'Mentoring'
];

const rows = [
  [
    { text: 'Określony czas szkoleń', icon: `${base}icons/MentoringTableIcons/timeSingle.svg` },
    { text: 'Liczba spotkań: od jednego do tylu ile potrzebujesz.', icon: `${base}icons/MentoringTableIcons/timeMentoring.svg` },
  ],
  [
    { text: 'Ogólne omówienie konkretnych dziedzin IT.', icon: `${base}icons/MentoringTableIcons/desiresSingle.svg` },
    { text: 'Możemy podejść specjalistycznie do danego wąskiego zagadnienia.', icon: `${base}icons/MentoringTableIcons/desiresMentoring.svg` },
  ],
  [
    { text: '5 tematów szkoleń.', icon: `${base}icons/MentoringTableIcons/subjectsSingle.svg` },
    { text: 'Liczba możliwych tematów jest nieograniczona.', icon: `${base}icons/MentoringTableIcons/subjectsMentoring.svg` },
  ],
  [
    { text: 'Pewne ustalone proporcje form nauki z mentorem - konkretna ilość webinarów, godzin indywidualnei z mentorem i pracy własnej.', icon: `${base}icons/MentoringTableIcons/proportionsSingle.svg` },
    { text: 'Dostosowane proporcje form nauki z mentorem - razem ustalamy ile czasu poświęcamy na przekazanie teorii, wspólną pracę, code review i pracę własną.', icon: `${base}icons/MentoringTableIcons/proportionsMentoring.svg` },
  ]
];

const {style, clazz} = Astro.props;
---

<Table headers={headers} rows={rows} style={style} clazz={clazz}/>
