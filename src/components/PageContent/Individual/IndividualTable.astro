---
// Importowanie komponentu Table
import Table from '../../SimpleTable/SimpleTable.astro';

const base = import.meta.env.BASE_URL;

const headers = [
  'Szkolenie grupowe', 
  'Szkolenie indywidualne'
];

const rows = [
  [
    { text: 'Tempo wspólne dla wszystkich.', icon: `${base}icons/individualTableIcons/lowSpeed.svg` },
    { text: 'Nie limituje Cię tempo innych osób.', icon: `${base}icons/individualTableIcons/mediumSpeed.svg` },
  ],
  [
    { text: 'Zmiana tematyki wymaga zainteresowania całej grupy.', icon: `${base}icons/individualTableIcons/groupSubject.svg` },
    { text: 'Tematyka dobierana do Twoich zainteresowań.', icon: `${base}icons/individualTableIcons/singleSubject.svg` },
  ],
  [
    { text: 'Wiele różnych mniejszych projektów.', icon: `${base}icons/individualTableIcons/fragments.svg` },
    { text: 'Szkolenie odbywa się na Twoim autorskim projekcie.', icon: `${base}icons/individualTableIcons/singleProject.svg` },
  ],
  [
    { text: 'Grupa do 6 osób.', icon: `${base}icons/individualTableIcons/people.svg` },
    { text: 'Tylko Ty.', icon: `${base}icons/individualTableIcons/singlePerson.svg` },
  ],
  [
    { text: 'Ustalony harmonogram.', icon: `${base}icons/individualTableIcons/groupCalendar.svg` },
    { text: 'Ty wybierasz terminy.', icon: `${base}icons/individualTableIcons/singleCalendar.svg` },
  ],
  [
    { text: '2h/3h/7h pracy indywidualnej z mentorem w zależności od pakietu.', icon: `${base}icons/individualTableIcons/limitedTime.svg` },
    { text: '18h/28h/51h pracy indywidualnej z mentorem w zależności od pakietu.', icon: `${base}icons/individualTableIcons/longTime.svg` },
  ],
  [
    { text: 'Czas z mentorem dzielony jest na całą grupę.', icon: `${base}icons/individualTableIcons/groupTeacher.svg` },
    { text: 'Mentor jest dla Ciebie nawet po godzinach trwaniach kursu.', icon: `${base}icons/individualTableIcons/singleTeacher.svg` },
  ],
  [
    { text: 'Zmiana kierunku wymaga znalezienie odpowiedniej grupy.', icon: `${base}icons/individualTableIcons/groupChange.svg` },
    { text: 'Jeśli w trakcie kursu poczujesz, że chcesz zmienić jego kierunek - możemy to zrealizować.', icon: `${base}icons/individualTableIcons/singleChange.svg` },
  ]
];
---

<Table headers={headers} rows={rows} />
