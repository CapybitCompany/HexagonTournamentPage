---
import ServerCounter from "../ServerCounter/ServerCounter.astro";
const {sourceIP} = Astro.props;
---

<div class="wrapperClass">
    <div class="generalContainer">
        <div class="containerGlow" aria-hidden="true"></div>
        <h2 class="copyHeader" data-copy={sourceIP}>MINECRAFT HEX</h2>
        <span class="copyHint">📋 Kliknij nagłówek, aby skopiować IP</span>
        <div class="contentWrapper">
            <slot/>
        </div>
        <div class="serverCounterWrapper">
          <ServerCounter sourceIP={sourceIP}/>
        </div>

        <div class="toast" id="copy-toast" aria-live="polite" aria-atomic="true"></div>
    </div>
</div>

<style>    
    .copyHeader{
        margin-bottom: 2px;
        margin-top: 15px;
        font-family: "minecraft";
        font-size: clamp(2rem, 5vw, 2.8rem);
        color: #fff;
        text-shadow:
            0 0 30px rgba(255, 166, 0, 0.5),
            0 0 60px rgba(255, 166, 0, 0.2),
            0 2px 8px rgba(0, 0, 0, 0.8);
        letter-spacing: 0.06em;
        transition: text-shadow 0.3s ease, color 0.3s ease;
    }

    .copyHeader:hover {
        color: var(--accent-color, #ffa600);
        text-shadow:
            0 0 40px rgba(255, 166, 0, 0.7),
            0 0 80px rgba(255, 166, 0, 0.3),
            0 2px 10px rgba(0, 0, 0, 0.9);
    }

    .wrapperClass {
        display: flex;
        flex-direction: column;
        width: 100%;
        color: white;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }

    .generalContainer{
        background-image: linear-gradient(
            rgba(0, 0, 0, 0.35),
            rgba(0, 0, 0, 0.92)
        ), url("/images/Welcome/dirt.webp");
        background-repeat: repeat; 
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 1220px;
        border-radius: 20px;
        align-items: center;
        padding-bottom: 16px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 166, 0, 0.15);
        box-shadow:
            0 20px 60px rgba(0, 0, 0, 0.6),
            0 0 40px rgba(255, 166, 0, 0.05);
    }

    .containerGlow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(255, 166, 0, 0.6), transparent);
        z-index: 2;
    }

    .copyHint {
        font-size: 0.82rem;
        opacity: 0.55;
        margin-bottom: 10px;
        letter-spacing: 0.03em;
        transition: opacity 0.3s ease;
    }

    .copyHeader:hover + .copyHint {
        opacity: 0.85;
    }

    .contentWrapper{
        display: flex;
        width: 100%;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        padding: 0 10px;
        box-sizing: border-box;
    }

    .serverCounterWrapper {
        width: 100%;
        margin-top: 16px;
        justify-content: center;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding-top: 12px;
    }

    .contentWrapper :global(.discordContainerWrapper) {
      flex: 0 0 calc(33.333% - 10px);
      max-width: calc(33.333% - 10px);
      min-width: 250px;
      margin: 0;
    }

    @media (max-width: 1200px) {
      .contentWrapper :global(.discordContainerWrapper) {
        flex: 0 0 calc(50% - 10px);
        max-width: calc(50% - 10px);
      }
    }

    .copyHeader { cursor: pointer; user-select: none; }

    .toast{
        position: fixed;
        left: 50%;
        bottom: 24px;
        transform: translateX(-50%);
        padding: 10px 14px;
        border-radius: 12px;
        background: rgba(0,0,0,0.8);
        color: white;
        font-size: 14px;
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s ease, transform .2s ease;
        z-index: 9999;
    }
    .toast.show{
        opacity: 1;
        transform: translateX(-50%) translateY(-6px);
    }

    @media (max-width: 980px) {
        .wrapperClass {
            width: 90%;
            margin-left: 5%;
            margin-right: 5%;
        }
        .contentWrapper{
            flex-direction: column;
            width: 90%;
            padding: 0;
        }

        .contentWrapper :global(.discordContainerWrapper) {
          flex: 0 0 100%;
          max-width: 100%;
          min-width: 100%;
        }

    }
</style>

<script>
  const header = document.querySelector(".copyHeader") as HTMLElement | null;
  const toast = document.getElementById("copy-toast") as HTMLElement | null;
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function showToast(text: string) {
    if (!toast) return;
    toast.textContent = text;
    toast.classList.add("show");
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove("show"), 3000);
  }

  async function copyText(text: string) {
    try {
      await navigator.clipboard.writeText(text);
      showToast(`Adres serwera skopiowano do schowka`);
    } catch {
      // fallback (gdy np. brak uprawnień)
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      ta.remove();
      showToast(`Adres serwera skopiowano do schowka`);
    }
  }

  if (header) {
    header.addEventListener("click", () => {
      const value = header.dataset.copy;
      if (!value) return showToast("Brak adresu do skopiowania.");
      copyText(value);
    });
  }
</script>