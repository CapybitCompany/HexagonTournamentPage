---
import "../../styles/global.css"
---

<button class="faqQuestion" type="button" aria-expanded="false">
    <span class="faqQuestionText"><slot/></span>
</button>

<style>
    .faqQuestion{
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffd88c;
        text-align: center;
        border: 0;
        background: transparent;
        cursor: pointer;
        padding: 0;
        margin: 0;
        font: inherit;
        font-size: clamp(1.12rem, 1.45vw, 1.28rem);
        font-weight: 700;
        line-height: 1.3;
        position: relative;
        padding-right: 20px;
    }

    .faqQuestionText {
        width: 100%;
        text-align: center;
    }

    .faqQuestion::after {
        content: "";
        position: absolute;
        top: 50%;
        right: 0;
        width: 7px;
        height: 7px;
        border-right: 2px solid #ffd88c;
        border-bottom: 2px solid #ffd88c;
        transform-origin: center;
        transform: translateY(-50%) rotate(-45deg);
        transition: transform 0.4s ease;
    }

    :global(.faqLine[data-expanded="true"] .faqQuestion::after) {
        transform: translateY(-50%) rotate(45deg);
    }
</style>