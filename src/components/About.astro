---
import NavBar from './NavBar/NavBar.astro'
import Footer from './Footer/Footer.astro'
import ContentContainer from './ContentContainer/ContentContainer.astro'
import './NavBar/NavBar.css'
import './PageContent/WelcomePage/Welcome.styles.css'
import FullImageContainer from './FullImageContainer/FullImageContainer.astro'
import Section from './ContentContainer/Section.astro'
import FAQ from './FAQ/FAQ.astro'
import FAQLine from './FAQ/FAQLine.astro'
import FAQQuestion from './FAQ/FAQQuestion.astro'
import FAQAnswer from './FAQ/FAQAnswer.astro'
import Breadcrumbs from './Breadcrumbs/Breadcrumbs.astro'
import { hexProjectStats } from '../data/hex-network'
const base = import.meta.env.BASE_URL;

const aboutFocusAreas = [
    {
        icon: '🏆',
        title: 'Turnieje i eventy',
        desc: 'Budujemy wydarzenia z jasnym celem, własnymi zasadami i rankingiem punktowym.'
    },
    {
        icon: '🌍',
        title: 'Staly serwer do grania',
        desc: 'Poza eventami rozwijamy swiat, do ktorego mozna wracac codziennie i budowac cos swojego.'
    },
    {
        icon: '🧩',
        title: 'Autorskie mechaniki',
        desc: 'Testujemy pluginy, mapy i formaty gry, ktore daja nam wiecej niz kolejny zwykly serwer.'
    },
    {
        icon: '💬',
        title: 'Discord jako centrum projektu',
        desc: 'To tam sa zapowiedzi, komunikacja z graczami, zapisy i feedback po kazdej edycji.'
    },
];

const aboutAudienceCards = [
    {
        label: '01',
        title: 'Dla graczy codziennych',
        desc: 'Jesli chcesz po prostu wpasc po szkole lub pracy i miec zyjacy serwer, znajdziesz tu swoje miejsce.'
    },
    {
        label: '02',
        title: 'Dla tych, ktorzy lubia rywalizacje',
        desc: 'Rankingi, eventy i sezonowe cele daja powod, zeby wracac i walczyc o cos wiecej niz sam survival.'
    },
    {
        label: '03',
        title: 'Dla ekip i znajomych',
        desc: 'HEX jest projektowany tak, by dalo sie tu jednoczesnie wspolpracowac, rywalizowac i tworzyc swoja historie.'
    },
];

const aboutValues = [
    {
        icon: '⚖️',
        title: 'Fair-play',
        desc: 'Dbamy o uczciwa rywalizacje i mechaniki, ktore nie rozwalaja balansu.'
    },
    {
        icon: '🤝',
        title: 'Szacunek',
        desc: 'Nie ma miejsca na toksycznosc, nękanie i chaos komunikacyjny.'
    },
    {
        icon: '🛡️',
        title: 'Bezpieczenstwo',
        desc: 'Moderacja, przejrzyste zasady i szybka reakcja sa czescia codziennego utrzymania projektu.'
    },
    {
        icon: '📣',
        title: 'Transparentnosc',
        desc: 'Zmiany, terminy i nagrody komunikujemy wprost, bez zgadywania po stronie graczy.'
    },
];

const aboutEventFlow = [
    {
        step: '01',
        title: 'Zapowiedz',
        desc: 'Najpierw pokazujemy motyw, zasady i termin, zeby kazdy wiedzial, o co gra.'
    },
    {
        step: '02',
        title: 'Zapisy i przygotowanie',
        desc: 'Zbieramy chetnych, dopinamy mape, pluginy i scenariusz konkretnej edycji.'
    },
    {
        step: '03',
        title: 'Rozgrywka',
        desc: 'Event ma tempo, emocje i czytelne cele. Ma byc widowiskowy, ale rowniez uczciwy.'
    },
    {
        step: '04',
        title: 'Ranking i nagrody',
        desc: 'Po wszystkim zostaje historia edycji, wyniki i punkty, ktore buduja dluzsza motywacje.'
    },
];

const aboutSupportPillars = [
    'hosting i infrastruktura',
    'narzedzia, zabezpieczenia i rozwój pluginow',
    'czas potrzebny na eventy, support i utrzymanie projektu',
];
---

<NavBar/>
<ContentContainer>
    <Breadcrumbs items={[{ label: "O nas" }]} />
    <FullImageContainer imagePath="images/About/about.jpeg" imageLink="#" wrapperClass="blackBackground aboutHeroBanner" imageClass="otherAspect" wrapperStyle="height: 420px;" altText="Zespol HEX Network i spolecznosc Minecraft podczas wydarzenia">
        <div class="aboutHeroOverlay"></div>
        <div class="aboutHeroContent">
            <span class="aboutHeroBadge">👥 O NAS</span>
            <h1 class="aboutBannerText">HEX Network</h1>
            <p class="aboutHeroSub">Polska społeczność i serwer Minecraft — turnieje, eventy, ranking graczy.</p>
        </div>
    </FullImageContainer>

    <Section>
        <section class="about">
            <header class="about__header reveal">
                <p>
                <b>HEX Network</b> to polska społeczność i serwer Minecraft, który łączy <b>turnieje, eventy, ranking graczy oraz autorskie tryby rozgrywki</b>.
                Zaczęliśmy od turniejów dla znajomych, a dziś budujemy miejsce, gdzie można rywalizować, współpracować i po prostu dobrze się bawić na co dzień.
                </p>
            </header>

            <section class="about__stats reveal" aria-label="Najwazniejsze informacje o HEX Network">
                <article class="about__statCard reveal-child" style="--reveal-i:0">
                    <span>Start projektu</span>
                    <strong>15.03.2025</strong>
                </article>
                <article class="about__statCard reveal-child" style="--reveal-i:1">
                    <span>Rozegrane turnieje</span>
                    <strong data-count-to={hexProjectStats.tournamentsPlayed}>0</strong>
                </article>
                <article class="about__statCard reveal-child" style="--reveal-i:2">
                    <span>Gracze w rankingach</span>
                    <strong data-count-to={hexProjectStats.rankedPlayers}>0</strong>
                </article>
                <article class="about__statCard reveal-child" style="--reveal-i:3">
                    <span>Na Discordzie</span>
                    <strong data-count-to={hexProjectStats.discordMembers}>0</strong>
                </article>
            </section>

            <section class="about__section about__focusSection reveal">
                <span class="about__eyebrow">Jak pracujemy</span>
                <h2>Co robimy</h2>
                <div class="about__focusGrid">
                    {aboutFocusAreas.map((item, index) => (
                        <article class="about__focusCard reveal-child" style={`--reveal-i:${index}`}>
                            <span class="about__focusIcon" aria-hidden="true">{item.icon}</span>
                            <h3>{item.title}</h3>
                            <p>{item.desc}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section class="about__section about__audienceSection reveal">
                <div class="about__audienceIntro">
                    <span class="about__eyebrow">Dla kogo to jest</span>
                    <h2>Dla graczy, ktorzy chca czegos wiecej niz pusty survival</h2>
                    <p>
                    HEX jest dla osob, ktore lubia Minecrafta, ale chca miec jednoczesnie <strong>staly serwer</strong>,
                    <strong>wydarzenia z emocjami</strong> i projekt, ktory zyje rowniez pomiedzy eventami.
                    Najczesciej trafiaja do nas nastolatkowie i mlodzi dorosli, ale kazdy szanujacy zasady jest mile widziany.
                    </p>
                </div>
                <div class="about__audienceCards">
                    {aboutAudienceCards.map((item, index) => (
                        <article class="about__audienceCard reveal-child" style={`--reveal-i:${index}`}>
                            <span class="about__audienceLabel">{item.label}</span>
                            <h3>{item.title}</h3>
                            <p>{item.desc}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section class="about__section about__valuesSection reveal">
                <span class="about__eyebrow">Zasady gry</span>
                <h2>Nasze zasady</h2>
                <div class="about__valuesGrid">
                    {aboutValues.map((item, index) => (
                        <article class="about__valueCard reveal-child" style={`--reveal-i:${index}`}>
                            <span class="about__valueIcon" aria-hidden="true">{item.icon}</span>
                            <h3>{item.title}</h3>
                            <p>{item.desc}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section class="about__section about__eventSection reveal">
                <span class="about__eyebrow">Od pomyslu do eventu</span>
                <h2>Jak dzialaja eventy i nagrody</h2>
                <div class="about__eventTimeline">
                    {aboutEventFlow.map((item, index) => (
                        <article class="about__eventCard reveal-child" style={`--reveal-i:${index}`}>
                            <span class="about__eventStep">{item.step}</span>
                            <h3>{item.title}</h3>
                            <p>{item.desc}</p>
                        </article>
                    ))}
                </div>
                <p class="about__eventNote">
                Konkretne zasady, terminy i pule nagrod publikujemy z wyprzedzeniem na Discordzie oraz w <a href={`${base}archive`}><b>archiwum eventow</b></a>.
                </p>
            </section>

            <section class="about__section about__supportSection reveal">
                <div class="about__supportIntro">
                    <span class="about__eyebrow">Zaplecze projektu</span>
                    <h2>Skad to wszystko sie bierze</h2>
                    <p>
                    Utrzymanie serwera i organizacja eventow kosztuja. Dlatego mamy sklep z opcjami wspierajacymi projekt,
                    ale naszym celem jest, aby wsparcie <strong>nie psulo rozgrywki</strong> i pozostawalo uczciwe wobec graczy.
                    </p>
                </div>
                <div class="about__supportGrid">
                    {aboutSupportPillars.map((item, index) => (
                        <div class="about__supportPillar reveal-child" style={`--reveal-i:${index}`}>
                            <span>{item}</span>
                        </div>
                    ))}
                </div>
                <p class="about__supportNote">
                Jesli chcesz zobaczyc, jak wyglada wsparcie projektu w praktyce, sprawdz <a href={`${base}shop`}><b>sklep HEX Network</b></a>.
                </p>
            </section>

            <section class="about__section about__linksSection reveal">
                <h2>Gdzie zacząć?</h2>
                <div class="about__linkGrid">
                    <a class="about__linkCard reveal-child" style="--reveal-i:0" href={base}>
                        <h3>Strona główna</h3>
                        <p>Poznaj aktualne turnieje, plany projektu i najważniejsze informacje o serwerze.</p>
                    </a>
                    <a class="about__linkCard reveal-child" style="--reveal-i:1" href={`${base}archive`}>
                        <h3>Archiwum eventów</h3>
                        <p>Zobacz poprzednie edycje, zwycięzców, nagrody i historię wydarzeń HEX.</p>
                    </a>
                    <a class="about__linkCard reveal-child" style="--reveal-i:2" href={`${base}contact`}>
                        <h3>Kontakt</h3>
                        <p>Masz pytanie, pomysł na współpracę albo chcesz odezwać się do administracji? Napisz do nas.</p>
                    </a>
                </div>
            </section>

            <section class="about__community reveal">
                <div class="about__communityImg">
                    <picture><source srcset={`${base}images/contact/discord.webp`} type="image/webp" /><img src={`${base}images/contact/discord.png`} alt="Discord HEX Network - dołącz do społeczności Minecraft" loading="lazy" decoding="async" /></picture>
                </div>
                <div class="about__communityText">
                    <h2>Dołącz do community</h2>
                    <p>Chcesz grać z nami, brać udział w eventach albo po prostu posiedzieć na Discordzie?
                        Wbijaj — tam znajdziesz aktualne informacje, zapowiedzi i linki do serwera.</p>
                    <div class="about__ctaRow">
                        <a class="about__ctaButton" href="https://discord.gg/e6SuCrQHak"><b>Dołącz na Discord</b></a>
                        <a class="about__ctaButton about__ctaGhost" href={base}><b>Zobacz stronę główną</b></a>
                    </div>
                </div>
            </section>

            <section class="about__section about__faqSection faqSection showcasePanel faqPanel reveal">
                <h2 class="about__faqHeading">FAQ - O nas</h2>
                <FAQ>
                    <FAQLine>
                        <FAQQuestion>Czym jest HEX Network?</FAQQuestion>
                        <FAQAnswer>HEX Network to polska społeczność i serwer Minecraft łączący turnieje, eventy, ranking graczy oraz rozwijane autorskie tryby rozgrywki.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Gdzie publikowane są informacje o eventach i turniejach?</FAQQuestion>
                        <FAQAnswer>Najważniejsze aktualizacje, zapowiedzi i harmonogramy publikujemy na stronie głównej, Discordzie HEX oraz w archiwum wydarzeń.</FAQAnswer>
                    </FAQLine>
                    <FAQLine>
                        <FAQQuestion>Jak mogę dołączyć do społeczności HEX?</FAQQuestion>
                        <FAQAnswer>Najlepiej zacząć od dołączenia na Discord. Tam znajdziesz bieżące ogłoszenia, informacje o serwerze i najbliższych wydarzeniach.</FAQAnswer>
                    </FAQLine>
                </FAQ>
            </section>
        </section>

    </Section>

</ContentContainer>
<Footer/>

<script>
/* === Scroll Reveal === */
const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
        if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            revealObserver.unobserve(entry.target);
        }
    });
}, { threshold: 0.15, rootMargin: "0px 0px -40px 0px" });

document.querySelectorAll(".reveal").forEach((el) => revealObserver.observe(el));

/* === Counting Numbers === */
const countObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const countTo = el.dataset.countTo;
        if (!countTo) return;
        const target = parseInt(countTo, 10);
        if (isNaN(target)) return;
        countObserver.unobserve(el);
        const duration = 1200;
        const start = performance.now();
        const animate = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(eased * target));
            if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
    });
}, { threshold: 0.5 });

document.querySelectorAll<HTMLElement>("[data-count-to]").forEach((el) => countObserver.observe(el));
</script>

<style>
    /* ===== SCROLL REVEAL ===== */
    .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.7s cubic-bezier(.22,1,.36,1), transform 0.7s cubic-bezier(.22,1,.36,1);
    }
    .reveal.revealed {
        opacity: 1;
        transform: translateY(0);
    }
    .reveal-child {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.5s cubic-bezier(.22,1,.36,1), transform 0.5s cubic-bezier(.22,1,.36,1);
        transition-delay: calc(var(--reveal-i, 0) * 120ms);
    }
    .revealed .reveal-child {
        opacity: 1;
        transform: translateY(0);
    }

    /* ===== DARK THEME ===== */
    :global(#main-content) {
        background: #0a0d12 !important;
        color: #e0d8cc !important;
    }

    /* ===== HERO ===== */
    :global(.aboutHeroBanner) {
        position: relative;
    }

    .aboutHeroOverlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg,
            rgba(0, 0, 0, 0.25) 0%,
            rgba(10, 13, 18, 0.7) 70%,
            #0a0d12 100%);
        z-index: 1;
        pointer-events: none;
    }

    .aboutHeroContent {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 100%;
        height: 100%;
        gap: 12px;
    }

    .aboutHeroBadge {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 999px;
        border: 1px solid rgba(255, 166, 0, 0.4);
        background: rgba(255, 166, 0, 0.1);
        color: var(--accent-color);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .aboutBannerText {
        color: white;
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-family: "minecraft";
        margin: 0;
        text-shadow: 0 0 40px rgba(255, 166, 0, 0.25), 0 4px 20px rgba(0, 0, 0, 0.7);
    }

    .aboutHeroSub {
        margin: 0;
        font-size: clamp(0.95rem, 1.4vw, 1.15rem);
        color: rgba(255, 255, 255, 0.7);
        max-width: 560px;
    }

    section {
        display: flex;
        flex-direction: column;
        width: 100%;
    }

    .about {
        gap: 28px;
        --about-panel-gradient: linear-gradient(155deg, #181d28 0%, #111620 55%, #0c0f16 100%);
        --about-card-bg: rgba(0, 0, 0, 0.32);
        --about-card-bg-hover: rgba(0, 0, 0, 0.45);
        --about-border: rgba(255, 255, 255, 0.08);
        --about-panel-shadow: 0 16px 48px rgba(0, 0, 0, 0.45);
    }

    .about__header {
        display: flex;
        flex-direction: column;
        gap: 12px;
        text-align: center;
        align-items: center;
    }

    .about__header p {
        max-width: 980px;
        margin: 0;
        line-height: 1.7;
        font-size: clamp(1.08rem, 1.35vw, 1.24rem);
        color: rgba(255, 255, 255, 0.8);
    }

    .about__header h1 {
        color: #fff;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
    }

    .about__stats {
        border-radius: 18px;
        padding: 18px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: var(--about-panel-gradient);
        box-shadow: var(--about-panel-shadow);
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        width: 100%;
        box-sizing: border-box;
        position: relative;
        overflow: hidden;
    }

    .about__stats::before,
    .about__section::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 10% 0%, rgba(255, 195, 87, 0.12), transparent 42%);
    }

    .about__statCard {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 8px;
        min-height: 120px;
        border: 1px solid var(--about-border);
        border-radius: 12px;
        background: var(--about-card-bg);
        padding: 12px;
        box-sizing: border-box;
        position: relative;
        z-index: 1;
    }

    .about__statCard span {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
    }

    .about__statCard strong {
        color: #fff;
        font-size: clamp(1.15rem, 1.8vw, 1.5rem);
        line-height: 1.2;
    }

    .about__section {
        border-radius: 18px;
        padding: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: var(--about-panel-gradient);
        box-shadow: var(--about-panel-shadow);
        position: relative;
        overflow: hidden;
        box-sizing: border-box;
        gap: 10px;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .about__eyebrow {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 166, 0, 0.22);
        background: rgba(255, 166, 0, 0.08);
        color: #ffd89d;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        position: relative;
        z-index: 1;
    }

    .about__section:hover {
        border-color: rgba(255, 166, 0, 0.15);
        box-shadow: 0 20px 56px rgba(0, 0, 0, 0.55), 0 0 24px rgba(255, 166, 0, 0.04);
    }

    .about__section p {
        margin: 0;
        line-height: 1.7;
        font-size: clamp(1.08rem, 1.35vw, 1.24rem);
        color: #f1eadb;
        position: relative;
        z-index: 1;
    }

    .about__section h2 {
        color: #fff;
        position: relative;
        z-index: 1;
        font-size: clamp(1.3rem, 2vw, 1.7rem);
    }

    .about__section h2::after {
        content: "";
        display: block;
        width: 50px;
        height: 3px;
        background: var(--accent-color);
        border-radius: 3px;
        margin: 8px auto 0;
        box-shadow: 0 0 14px rgba(255, 166, 0, 0.4);
    }

    .about__section strong {
        color: #ffe4b6;
    }

    .about__section a {
        color: #ffe39f;
        position: relative;
        z-index: 1;
    }

    .about__section a:hover {
        color: #ffd88c;
    }

    .about__linksSection {
        align-items: stretch;
    }

    .about__focusGrid,
    .about__valuesGrid,
    .about__eventTimeline,
    .about__supportGrid {
        position: relative;
        z-index: 1;
    }

    .about__focusGrid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .about__focusCard,
    .about__valueCard,
    .about__eventCard,
    .about__supportPillar,
    .about__audienceCard {
        border: 1px solid var(--about-border);
        background: var(--about-card-bg);
        border-radius: 14px;
        box-sizing: border-box;
        transition: transform 0.22s ease, border-color 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
    }

    .about__focusCard {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 18px;
    }

    .about__focusCard:hover,
    .about__valueCard:hover,
    .about__eventCard:hover,
    .about__supportPillar:hover,
    .about__audienceCard:hover {
        transform: translateY(-3px);
        border-color: rgba(255, 210, 120, 0.28);
        background: var(--about-card-bg-hover);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
    }

    .about__focusIcon,
    .about__valueIcon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(145deg, rgba(255, 166, 0, 0.24), rgba(255, 166, 0, 0.08));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
        font-size: 1.15rem;
    }

    .about__focusCard h3,
    .about__valueCard h3,
    .about__eventCard h3,
    .about__audienceCard h3 {
        margin: 0;
        color: #fff;
        position: relative;
        z-index: 1;
        font-size: 1.1rem;
    }

    .about__focusCard p,
    .about__valueCard p,
