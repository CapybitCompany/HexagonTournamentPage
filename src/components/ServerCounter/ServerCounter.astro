---
const {sourceIP} = Astro.props;
---

<div id="mc-status">
  <span class="mc-label">Aktywni gracze:</span>
  <span class="mc-count" id="mc-players">...</span>
</div>

<style>
  #mc-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: "minecraft";
    font-weight: bold;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.7);
    padding: 4px 0;
  }

  .mc-label {
    opacity: 0.7;
  }

  .mc-count {
    color: var(--accent-color, #ffa600);
    text-shadow: 0 0 12px rgba(255, 166, 0, 0.35);
  }
</style>

<script define:vars={{sourceIP}}>
  const SERVER_IP = 'MinecraftHEX.pl';

  async function loadPlayers() {
    try {
      const res = await fetch(`https://api.mcsrvstat.us/2/${sourceIP}`);
      const data = await res.json();

      const el = document.getElementById('mc-players');
      if (!el) return;

      if (data && data.players && typeof data.players.online === 'number') {
        el.textContent = " " + data.players.online + " / " + data.players.max;
      } else {
        el.textContent = 'offline';
      }
    } catch (e) {
      console.error(e);
      const el = document.getElementById('mc-players');
      if (el) el.textContent = 'błąd';
    }
  }

  loadPlayers();
</script>

