---
import NavBar from './NavBar/NavBar.astro'
import Footer from './Footer/Footer.astro'
import ContentContainer from './ContentContainer/ContentContainer.astro'
import './NavBar/NavBar.css'
import './PageContent/WelcomePage/Welcome.styles.css'
import FullImageContainer from './FullImageContainer/FullImageContainer.astro'
import DiscordContainer from './DiscordContainer/DiscordContainer.astro'
import HexContainer from './DiscordContainer/HexContainer.astro'
import TimeContainer from './DiscordContainer/TimeContainer.astro'
import ServerContainerWrapper from './DiscordContainer/ServerContainerWrapper.astro'
import Section from './ContentContainer/Section.astro'
import FAQ from './FAQ/FAQ.astro'
import FAQLine from './FAQ/FAQLine.astro'
import FAQQuestion from './FAQ/FAQQuestion.astro'
import FAQAnswer from './FAQ/FAQAnswer.astro'
import { homepageHeroStats, homepageStatsGrid, homepageTimeline, serverRoadmap } from '../data/hex-network';
const base = import.meta.env.BASE_URL;
---

<NavBar/>
<ContentContainer>
    <FullImageContainer id="mainBanner" imagePath="images/Welcome/Banner.jpg" imageLink="#" wrapperClass="blackBackground banner heroBanner" imageClass="fade-image" altText="Turniej Minecraft HEX - serwer Minecraft Polska, event i ranking graczy" priority={true}>
    <div class="heroOverlay"></div>
    <div class="heroParticles" aria-hidden="true">
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
    </div>
    <div class="bannerHero">
        <span class="heroBadge">⚔️ SERWER MINECRAFT POLSKA</span>
        <h1 class="bannerTitle">HEX NETWORK</h1>
        <p class="bannerSubtitle">Turnieje z nagrodami · Eventy · Rankingi graczy · Autorskie tryby</p>
        <div class="heroCtas">
            <a class="welcomeButton bannerCta glowBtn" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer"><b>Dołącz na Discord</b></a>
            <a class="welcomeButton bannerCtaOutline" href="#servers"><b>Poznaj serwery ↓</b></a>
        </div>
    </div>
    <div class="scrollIndicator" aria-hidden="true"><span></span></div>
    </FullImageContainer>

    <aside class="heroSocialProof" aria-label="Kluczowe liczby HEX Network">
        {homepageHeroStats.map((item, index) => (
            <>
                <span class="heroSocialProofItem"><span class="heroSocialProofIcon" aria-hidden="true">{item.icon}</span><strong>{item.value}</strong> {item.label}</span>
                {index < homepageHeroStats.length - 1 && <span class="heroSocialProofSep" aria-hidden="true"></span>}
            </>
        ))}
    </aside>

    <div id="servers" style="display: flex; width: 100%; justify-content: center;">    
        <TimeContainer />
    </div>


    <ServerContainerWrapper sourceIP="MinecraftHEX.pl">

        <HexContainer src="images/Welcome/ServerBanner1.png" headerText="EVENT ZONE" href={`${base}hexEvent`}/>

        {serverRoadmap.map((item) => (
            <HexContainer headerText={item.headerText} href={`${base}${item.href}`} comingSoon={true} soonText="Niebawem" progress={item.progress} eta={item.eta}/>
        ))}

    </ServerContainerWrapper>

    <Section>
        <h2>Czym jest Minecraft HEX</h2>
        <div class="seoIntro">
            <p><b>Minecraft HEX</b> to polska społeczność Minecraft oparta na <b>turniejach, sezonach rankingowych i eventach z nagrodami</b>. Rywalizuj, zdobywaj punkty i awansuj w rankingu graczy. Dodatkowo 
                graj na naszych serwerach z <b>tworzonymi przez nas pluginami</b>, które wprowadzają <b>unikalne tryby i mechaniki</b>.
            </p>
        </div>
    </Section>

    <Section>
        <h2>HEX w liczbach</h2>
        <div class="showcasePanel socialProofPanel">
            <div class="showcaseGrid socialProofGrid">
                {homepageStatsGrid.map((item) => (
                    <article class="showcaseCard socialProofItem"><p class="timelineLabel">{item.label}</p><h3 data-days-from={item.daysFrom}>{item.value}</h3></article>
                ))}
            </div>
        </div>
    </Section>


    <Section>
        <h2>Aktualności i plany</h2>
        <div class="showcasePanel updatesPanel">
            <p class="showcaseLead">Oficjalne aktualizacje projektu HEX Network: terminy turniejów, nowe tryby, sezony rankingowe i najważniejsze premiery serwera.</p>
            <ol class="updatesTimeline">
                {homepageTimeline.map((item) => (
                    <li class="updatesTimelineItem">
                        <div class="updatesTimelineDot" aria-hidden="true"></div>
                        <div class="updatesTimelineContent">
                            <div class="updatesTimelineMeta">
                                <time class="updatesTimelineDate" datetime={item.dateTime}>{item.date}</time>
                                <span class={`updatesTimelineTag ${item.tagClass}`}>{item.tag}</span>
                            </div>
                            <h3>{item.title}</h3>
                            <p>{item.description}</p>
                            {item.href && item.cta && <a class="updatesTimelineLink" href={`${base}${item.href}`}>{item.cta}</a>}
                        </div>
                    </li>
                ))}
            </ol>
            <div class="updatesTimelineFooter">
                <a class="updatesTimelineAllLink" href={`${base}devlog`}>Zobacz pełen devlog →</a>
            </div>
        </div>
    </Section>

    <Section>
        <h2>Dlaczego warto zagrać?</h2>
        <div class="showcasePanel benefitsPanel">
            <div class="showcaseGrid benefitsGrid">
                <article class="showcaseCard benefitCard"><span class="benefitIcon">⚔️</span><h3>Turnieje z nagrodami</h3><p>Rywalizuj w cyklicznych turniejach z realnymi nagrodami pieniężnymi i zdobywaj punkty rankingowe.</p></article>
                <article class="showcaseCard benefitCard"><span class="benefitIcon">📊</span><h3>Ranking sezonowy i roczny</h3><p>Śledź swoje postępy, awansuj w klasyfikacji i walcz o miano najlepszego gracza sezonu.</p></article>
                <article class="showcaseCard benefitCard"><span class="benefitIcon">💬</span><h3>Aktywna społeczność</h3><p>Dołącz do zaangażowanej społeczności na Discordzie, która wspólnie tworzy wydarzenia i nowe tryby.</p></article>
                <article class="showcaseCard benefitCard"><span class="benefitIcon">🎮</span><h3>Regularne eventy i tryby</h3><p>Co miesiąc nowe wydarzenia, autorskie mini-gry i oryginalne mechaniki tworzone przez nasz zespół.</p></article>
            </div>
        </div>
    </Section>

    <Section>
        <h2>Jak dołączyć na serwer?</h2>
        <div class="showcasePanel joinPanel">
            <div class="showcaseGrid joinGrid">
                <article class="showcaseCard joinStep">
                    <span class="joinStepNumber">1</span>
                    <h3>Minecraft Java Edition</h3>
                    <p>Zadziała zarówno wersja premium, jak i non-premium. Wymagana wersja gry: 1.21 – 1.21.11.</p>
                </article>
                <article class="showcaseCard joinStep">
                    <span class="joinStepNumber">2</span>
                    <h3>Wpisz adres serwera</h3>
                    <p>W Minecraft dodaj serwer i wpisz adres: <strong>MinecraftHEX.pl</strong></p>
                </article>
                <article class="showcaseCard joinStep">
                    <span class="joinStepNumber">3</span>
                    <h3>Wybierz tryb w lobby</h3>
                    <p>Po wejściu na serwer wybierz interesujący Cię tryb gry przez portal lub kompas.</p>
                </article>
            </div>
        </div>
    </Section>

    <Section>
        <h2 class="spotlightSectionTitle">Sklep i Archiwum</h2>
        <div class="spotlightGrid">
            <a href={`${base}shop`} class="spotlightCard">
                <div class="spotlightCardBg" style={`background-image: url('${base}images/Welcome/Shop.jpg');`}></div>
                <div class="spotlightCardOverlay"></div>
                <div class="spotlightCardInner">
                    <span class="spotlightIcon">🛒</span>
                    <h3 class="spotlightCardTitle">Sklep HEX</h3>
                    <p class="spotlightCardText">Pakiety VIP i HexCoins, które pozwalają na dodatki kosmetyczne i elementy QoL.</p>
                    <span class="spotlightCta">Przejdź do sklepu →</span>
                </div>
            </a>
            <a href={`${base}archive`} class="spotlightCard">
                <div class="spotlightCardBg" style={`background-image: url('${base}images/Welcome/Archive.png');`}></div>
                <div class="spotlightCardOverlay"></div>
                <div class="spotlightCardInner">
                    <span class="spotlightIcon">🏆</span>
                    <h3 class="spotlightCardTitle">Archiwum eventów</h3>
                    <p class="spotlightCardText">Zwycięzcy, pule nagród, daty i kluczowe momenty poprzednich turniejów.</p>
                    <span class="spotlightCta">Zobacz archiwum →</span>
                </div>
            </a>
        </div>
    </Section>

    <Section>
        <div class="faqSection showcasePanel faqPanel">
            <h2>FAQ - serwer Minecraft HEX</h2>
            <FAQ>
                <FAQLine>
                    <FAQQuestion>Jak zapisać się na turniej Minecraft?</FAQQuestion>
                    <FAQAnswer>Większość wydarzeń nie wymaga wcześniejszych zapisów. Dołącz na nasz Discord, obserwuj nasz TikTok, Instagram lub YouTube i śledź ogłoszenia, aby być na bieżąco.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co dają punkty?</FAQQuestion>
                    <FAQAnswer>Punkty rankingowe pozwalają śledzić postępy graczy, zdobywać nagrody i awansować w rankingach sezonowych oraz rocznych.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co to jest sezon?</FAQQuestion>
                    <FAQAnswer>Sezon to okres, w którym gracze rywalizują o punkty rankingowe. Na koniec sezonu przyznawane są nagrody i aktualizowane rankingi. Terminy sezonów są ustalane przez administrację serwera i będą wyświetlane na stronie oraz ogłaszane na naszym Discordzie.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Kiedy pojawią się kolejne serwery?</FAQQuestion>
                    <FAQAnswer>Informacje o nowych serwerach będą ogłaszane na naszym Discordzie oraz na stronie internetowej. Śledź nasze kanały, aby być na bieżąco z nowościami. Planujemy wprowadzać je cyklicznie w kolejnych miesiącach.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Jak grać w różne tryby?</FAQQuestion>
                    <FAQAnswer>Po wejściu na serwer Minecraft, trafiasz do lobby, skąd możesz wybrać interesujący Cię tryb gry przechodząc przez odpowiedni portal lub poprzez użycie kompasu.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co muszę zrobić aby dołączyć na serwer?</FAQQuestion>
                    <FAQAnswer>Musisz posiadać Minecraft Java Edition. Zadziała zarówno wersja premium, jak i non-premium. Wymagana jest dowolna wersja gry 1.21 - 1.21.1. Skopiuj adres serwera i wklej go w Minecraft, aby dołączyć.</FAQAnswer>
                </FAQLine>
            </FAQ>
        </div>
    </Section>



</ContentContainer>
<Footer/>

<script>
    const socialProofGrid = document.querySelector(".socialProofGrid");

    if (socialProofGrid instanceof HTMLElement) {
        const numberElements = socialProofGrid.querySelectorAll("h3");
        const animationDurationMs = 2500;
        let hasAnimated = false;

        const prefersReducedMotion = typeof window.matchMedia === "function"
            && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const daysElement = socialProofGrid.querySelector("h3[data-days-from]");
        if (daysElement instanceof HTMLElement) {
            const daysFromValue = daysElement.getAttribute("data-days-from");

            if (daysFromValue) {
                const startDate = new Date(`${daysFromValue}T00:00:00`);
                const now = new Date();
                const msPerDay = 1000 * 60 * 60 * 24;
                const daysDiff = Math.floor((now.getTime() - startDate.getTime()) / msPerDay);
                const safeDays = Math.max(0, daysDiff);
                daysElement.textContent = String(safeDays);
            }
        }

        numberElements.forEach((element) => {
            const rawValue = element.textContent ?? "0";
            const parsedValue = Number.parseInt(rawValue.replace(/\D/g, ""), 10);
            const targetValue = Number.isNaN(parsedValue) ? 0 : parsedValue;

            element.setAttribute("data-target", String(targetValue));
        });

        if (prefersReducedMotion) {
            // Respect user preference: show final values immediately, no animation.
            numberElements.forEach((element) => {
                const targetValue = element.getAttribute("data-target") ?? "0";
                element.textContent = targetValue;
            });
        } else {
            const startCountAnimation = () => {
                if (hasAnimated) {
                    return;
                }

                hasAnimated = true;
                numberElements.forEach((element) => {
                    element.textContent = "0";
                });
                const animationStart = performance.now();

                const tick = () => {
                    const now = performance.now();
                    const progress = Math.min((now - animationStart) / animationDurationMs, 1);

                    numberElements.forEach((element) => {
                        const targetValue = Number.parseInt(element.getAttribute("data-target") ?? "0", 10);
                        const nextValue = Math.round(targetValue * progress);
                        element.textContent = String(nextValue);
                    });

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    }
                };

                requestAnimationFrame(tick);
            };

            const isInViewport = () => {
                const rect = socialProofGrid.getBoundingClientRect();
                const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                return rect.top < viewportHeight && rect.bottom > 0;
            };

            if ("IntersectionObserver" in window) {
                const counterObserver = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (!entry.isIntersecting) {
                                return;
                            }

                            startCountAnimation();
                            counterObserver.disconnect();
                        });
                    },
                    { threshold: 0.35 }
                );

                counterObserver.observe(socialProofGrid);

                // If the grid is already in viewport at load time, kick off immediately.
                if (isInViewport()) {
                    startCountAnimation();
                    counterObserver.disconnect();
                }
            } else {
                startCountAnimation();
            }
        }
    }

    // Scroll Reveal
    const revealSections = document.querySelectorAll(".sectionContainer");
    if ("IntersectionObserver" in window) {
        const revealObs = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("revealed");
                        revealObs.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
        );
        revealSections.forEach((s) => revealObs.observe(s));
    } else {
        revealSections.forEach((s) => s.classList.add("revealed"));
    }

</script>

<style>

    /* ===== DARK THEME ===== */
    :global(#main-content) {
        background: #0a0d12 !important;
        color: #e0d8cc !important;
    }

    /* ===== SCROLL REVEAL ===== */
    :global(.sectionContainer) {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
        margin-bottom: 50px;
    }
    :global(.sectionContainer.revealed) {
        opacity: 1;
        transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
        :global(.sectionContainer) { opacity: 1; transform: none; transition: none; }
    }

    /* ===== SECTION HEADING ACCENT ===== */
    h2 { color: #fff; }
    h2:not(.faqToggleHeading)::after {
        content: "";
        width: 60px;
        height: 3px;
        background: var(--accent-color);
        border-radius: 3px;
        box-shadow: 0 0 14px rgba(255, 166, 0, 0.4);
        margin-top: 10px;
        align-self: center;
    }

    /* ===== HERO BANNER ===== */
    :global(.heroBanner) {
        height: 100vh !important;
        margin-top: 0 !important;
        min-height: 580px;
    }

    .heroOverlay {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 50% 18%, rgba(255, 166, 0, 0.16), transparent 34%),
            linear-gradient(180deg,
                rgba(0,0,0,0.28) 0%,
                rgba(8,9,10,0.68) 58%,
                #090a0d 100%);
        z-index: 1;
        pointer-events: none;
    }

    /* --- Floating particles --- */
    .heroParticles {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        overflow: hidden;
    }
    .particle {
        position: absolute;
        display: block;
        width: 6px; height: 6px;
        background: rgba(255, 158, 54, 0.78);
        border-radius: 1px;
        box-shadow: 0 0 12px rgba(255, 150, 46, 0.35);
        animation: floatUp linear infinite;
        opacity: 0;
    }
    .particle:nth-child(1)  { left: 8%;  width: 5px; height: 5px; animation-duration: 14s; animation-delay: 0s; }
    .particle:nth-child(2)  { left: 18%; width: 4px; height: 4px; animation-duration: 18s; animation-delay: 2s; }
    .particle:nth-child(3)  { left: 30%; width: 7px; height: 7px; animation-duration: 12s; animation-delay: 4s; }
    .particle:nth-child(4)  { left: 42%; width: 5px; height: 5px; animation-duration: 16s; animation-delay: 1s; }
    .particle:nth-child(5)  { left: 55%; width: 3px; height: 3px; animation-duration: 20s; animation-delay: 3s; }
    .particle:nth-child(6)  { left: 65%; width: 6px; height: 6px; animation-duration: 13s; animation-delay: 5s; }
    .particle:nth-child(7)  { left: 76%; width: 4px; height: 4px; animation-duration: 17s; animation-delay: 0.5s; }
    .particle:nth-child(8)  { left: 85%; width: 5px; height: 5px; animation-duration: 15s; animation-delay: 2.5s; }
    .particle:nth-child(9)  { left: 22%; width: 3px; height: 3px; animation-duration: 19s; animation-delay: 6s; }
    .particle:nth-child(10) { left: 50%; width: 8px; height: 8px; animation-duration: 11s; animation-delay: 1.5s; }
    .particle:nth-child(11) { left: 72%; width: 5px; height: 5px; animation-duration: 16s; animation-delay: 4.5s; }
    .particle:nth-child(12) { left: 92%; width: 4px; height: 4px; animation-duration: 14s; animation-delay: 3.5s; }
    .particle:nth-child(13) { left: 12%; width: 6px; height: 6px; animation-duration: 15s; animation-delay: 1.8s; }
    .particle:nth-child(14) { left: 38%; width: 4px; height: 4px; animation-duration: 17s; animation-delay: 3.2s; }
    .particle:nth-child(15) { left: 60%; width: 5px; height: 5px; animation-duration: 13s; animation-delay: 0.8s; }
    .particle:nth-child(16) { left: 80%; width: 7px; height: 7px; animation-duration: 16s; animation-delay: 5.5s; }
    .particle:nth-child(17) { left: 48%; width: 3px; height: 3px; animation-duration: 19s; animation-delay: 2.8s; }
    .particle:nth-child(18) { left: 28%; width: 5px; height: 5px; animation-duration: 14s; animation-delay: 4.2s; }

    @keyframes floatUp {
        0%   { transform: translate3d(0, 105vh, 0) rotate(0deg); opacity: 0; }
        10%  { opacity: 0.85; }
        90%  { opacity: 0.6; }
        100% { transform: translate3d(0, -12vh, 0) rotate(180deg); opacity: 0; }
    }

    @keyframes fadeInHero {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .heroBadge {
        display: inline-block;
        padding: 6px 18px;
        border-radius: 999px;
        border: 1px solid rgba(255, 166, 0, 0.4);
        background: rgba(255, 166, 0, 0.1);
        color: var(--accent-color);
        font-size: clamp(0.72rem, 1.1vw, 0.92rem);
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-shadow: none;
        opacity: 0;
        animation: fadeInHero 0.6s ease forwards 1.2s;
    }

    /* --- Scroll indicator --- */
    .scrollIndicator {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 3;
    }
    .scrollIndicator span {
        display: block;
        width: 22px; height: 22px;
        border-right: 2px solid rgba(255,255,255,0.45);
        border-bottom: 2px solid rgba(255,255,255,0.45);
        transform: rotate(45deg);
        animation: scrollBounce 2s ease-in-out infinite;
    }
    @keyframes scrollBounce {
        0%, 20%, 50%, 80%, 100% { transform: rotate(45deg) translateY(0); }
        40% { transform: rotate(45deg) translateY(8px); }
        60% { transform: rotate(45deg) translateY(4px); }
    }

    .heroCtas {
        display: flex;
        gap: 14px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 6px;
        opacity: 0;
        animation: fadeInHero 0.6s ease forwards 2s;
    }

    .glowBtn {
        box-shadow: 0 0 20px rgba(255,166,0,0.4), 0 0 60px rgba(255,166,0,0.15);
        background: linear-gradient(90deg, var(--brand-accent, #ffa600), #ff7a00, var(--brand-accent, #ffa600)) !important;
        background-size: 200% 100% !important;
        animation: heroCtaShimmer 4s linear infinite;
    }
    @keyframes heroCtaShimmer {
        0%   { background-position: 0% 50%; }
        100% { background-position: 200% 50%; }
    }
    @media (prefers-reduced-motion: reduce) {
        .glowBtn { animation: none; }
    }

    .bannerCtaOutline {
        background: transparent !important;
        border: 2px solid rgba(255,255,255,0.45);
        color: #fff !important;
        box-shadow: none !important;
        margin-top: 0;
    }
    .bannerCtaOutline:hover {
        background: rgba(255,255,255,0.1) !important;
        border-color: #fff;
        transform: translateY(-2px);
    }
    .bannerCtaOutline b { color: #fff; }

    /* ===== BANNER IMAGE ANIMATION ===== */
    @keyframes fadeIn {
        from { opacity: 0; transform: scale(10); }
        to   { opacity: 1; transform: scale(1); }
    }

    .bannerHero {
        width: min(900px, 92%);
        margin: 0 auto;
        height: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 16px;
        color: white;
        text-align: center;
        z-index: 3;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
    }

    .bannerTitle {
        margin: 0;
        font-family: 'Minecraft', 'Montserrat', sans-serif;
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 1.05;
        font-weight: 700;
        color: #fff;
        text-shadow: 0 0 40px rgba(255,166,0,0.3), 0 4px 20px rgba(0,0,0,0.7);
        opacity: 0;
        animation: fadeInHero 0.7s ease forwards 1.4s;
    }

    .bannerSubtitle {
        margin: 0;
        max-width: 700px;
        font-size: clamp(1rem, 1.5vw, 1.3rem);
        line-height: 1.5;
        color: rgba(255,255,255,0.8);
        opacity: 0;
        animation: fadeInHero 0.6s ease forwards 1.7s;
    }

    .bannerCta {
