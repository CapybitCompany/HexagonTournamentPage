---
import NavBar from './NavBar/NavBar.astro'
import Footer from './Footer/Footer.astro'
import ContentContainer from './ContentContainer/ContentContainer.astro'
import ImageBoxContent from './ImageBoxContent/ImageBoxContent.astro'
import './NavBar/NavBar.css'
import './PageContent/WelcomePage/Welcome.styles.css'
import FullImageContainer from './FullImageContainer/FullImageContainer.astro'
import DiscordContainer from './DiscordContainer/DiscordContainer.astro'
import HexContainer from './DiscordContainer/HexContainer.astro'
import TimeContainer from './DiscordContainer/TimeContainer.astro'
import ServerContainerWrapper from './DiscordContainer/ServerContainerWrapper.astro'
import Section from './ContentContainer/Section.astro'
import FAQ from './FAQ/FAQ.astro'
import FAQLine from './FAQ/FAQLine.astro'
import FAQQuestion from './FAQ/FAQQuestion.astro'
import FAQAnswer from './FAQ/FAQAnswer.astro'

---

<NavBar/>
<ContentContainer>
    <FullImageContainer id="mainBanner" imagePath="images/Welcome/Banner.jpg" imageLink="#" wrapperClass="blackBackground banner" imageClass="fade-image" altText="Turniej Minecraft HEX - serwer Minecraft Polska, event i ranking graczy">
    <div class="bannerHero">
        <h1 class="bannerTitle">Turnieje Minecraft, serwery i wyzwania!</h1>
        <a class="welcomeButton bannerCta" href="https://discord.gg/e6SuCrQHak" target="_blank" rel="noopener noreferrer"><b>Dołącz</b></a>
    </div>
    </FullImageContainer>

     <div style="display: flex; width: 100%; justify-content: center;">    
        <TimeContainer />
    </div>


    <ServerContainerWrapper sourceIP="Minecrafthex.pl">

        <HexContainer src="images/Welcome/ServerBanner1.png" headerText="EVENT ZONE" href="/hexEvent"/>

        <HexContainer src="images/Welcome/ServerBanner2.png" headerText="MINI GAMES" href="/hexMiniGames"/>

        <HexContainer headerText="PARKOUR" href="/hexParkour" comingSoon={true} soonText="Niebawem"/>

        <HexContainer headerText="PVP" href="/hexPvp" comingSoon={true} soonText="Niebawem"/>

        <HexContainer headerText="HARDCORE SMP" href="/hexHardcoreSmp" comingSoon={true} soonText="Niebawem"/>

    </ServerContainerWrapper>

    <Section>
        <h2>Czym jest Minecraft Hex</h2>
        <div class="seoIntro">
            <p><b>Minecraft Hex</b> to polska społeczność Minecraft oparta na <b>turniejach, sezonach rankingowych i eventach z nagrodami</b>. Rywalizuj, zdobywaj punkty i awansuj w klasyfikacji graczy. Dodatkowo 
                graj na naszych serwerach z <b>tworzonymi przez nas pluginami, które wprowadzają unikalne tryby i mechaniki</b>.
            </p>
        </div>
    </Section>

    <Section>
        <h2>HEX w liczbach</h2>
        <div class="showcasePanel socialProofPanel">
            <div class="showcaseGrid socialProofGrid">
                <article class="showcaseCard socialProofItem"><p class="timelineLabel">Rozegranych turniejow</p><h3>6</h3></article>
                <article class="showcaseCard socialProofItem"><p class="timelineLabel">Graczy w rankingach</p><h3>44</h3></article>
                <article class="showcaseCard socialProofItem"><p class="timelineLabel">Członków Discord</p><h3>121</h3></article>
                <article class="showcaseCard socialProofItem"><p class="timelineLabel">Dni naszej działalności</p><h3 data-days-from="2025-03-15">0</h3></article>
            </div>
        </div>
    </Section>


    <Section>
        <h2>Aktualności i plany</h2>
        <div class="showcasePanel updatesPanel">
            <div class="updatesList">
                <article class="showcaseCard updatesItem">
                    <div class="updatesMedia" aria-hidden="true">
                        <img src="images/Welcome/Activities/Term.jpg" alt="Najbliższy turniej 3.04.2026 o godzinie 19:00."/>
                    </div>
                    <div class="updatesContent">
                        <h3>Hex VII — 3.04.2026, 19:00</h3>
                        <p>Najbliższy turniej z pulą nagród i punktami do rankingu.</p>
                    </div>
                </article>
                <article class="showcaseCard updatesItem">
                    <div class="updatesMedia" aria-hidden="true">
                        <img src="images/Welcome/Activities/Minigames.jpg" alt="Start Minigames w okolicy końca kwietnia."/>
                    </div>
                    <div class="updatesContent">
                        <h3>Start Minigames — koniec kwietnia</h3>
                        <p>Ruszamy z nowym segmentem luźniejszych trybów i oryginalnymi mini-grami.</p>
                    </div>
                </article>
                <article class="showcaseCard updatesItem">
                    <div class="updatesMedia" aria-hidden="true">
                        <img src="images/Welcome/Activities/Castle.jpg" alt="W 2027 startuje HexHogwart inspirowany światem magii w klimatach RPG."/>
                    </div>
                    <div class="updatesContent">
                        <h3>HexHogwart — w budowie</h3>
                        <p>Trwają prace nad nowym światem i mechanikami RPG.</p>
                    </div>
                </article>
                <article class="showcaseCard updatesItem">
                    <div class="updatesMedia" aria-hidden="true">
                        <img src="images/Welcome/Activities/Rank.jpg" alt="Nasz serwer posiada rankingi najlepszych graczy sezonowo i rocznie."/>
                    </div>
                    <div class="updatesContent">
                        <h3>Nowy sezon rankingowy — wkrótce</h3>
                        <p>Przygotuj się na nową klasyfikację i walkę o topkę.</p>
                    </div>
                </article>
            </div>
        </div>
    </Section>

    <Section>
        <h2>Dlaczego warto zagrać?</h2>
        <div class="showcasePanel benefitsPanel">
            <div class="showcaseGrid benefitsGrid">
                <article class="showcaseCard"><h3>Turnieje z nagrodami</h3></article>
                <article class="showcaseCard"><h3>Ranking sezonowy i roczny</h3></article>
                <article class="showcaseCard"><h3>Aktywna społeczność i fajni admini</h3></article>
                <article class="showcaseCard"><h3>Regularne eventy i nowe tryby</h3></article>
            </div>
        </div>
    </Section>

    <Section>
        <h2 class="spotlightSectionTitle">Sklep Minecraft HEX i archiwum eventów</h2>

        <ImageBoxContent imagePath="images/Welcome/Shop.jpg" wrapperClass="bottomGap imageRight welcomeFeatureBox" lazyMeanColor="#e5e3dd" altText="Sklep serwera Minecraft HEX - nagrody i pakiety">
            <div class="fullWidthTileContent spotlightTile" >
                <h3 class="spotlightCardTitle">Sklep serwera Minecraft HEX</h3>
                <p class="spotlightCardText">Sprawdź pakiety VIP i dodatki, które wspierają rozwój projektu oraz organizację turniejów Minecraft.</p>
                <a class="spotlightLink welcomeButton" href="/shop"><b>Przejdź do sklepu</b></a>
            </div>
        </ImageBoxContent>
        <ImageBoxContent imagePath="images/Welcome/Archive.png" wrapperClass="bottomGap welcomeFeatureBox" lazyMeanColor="#596872" altText="Archiwum turniejów Minecraft HEX - wyniki i relacje">
            <div class="fullWidthTileContent spotlightTile" >
                <h3 class="spotlightCardTitle">Archiwum eventów Minecraft</h3>
                <p class="spotlightCardText">Zobacz poprzednie edycje turniejów HEX: zwycięzców, pule nagród, daty wydarzeń i kluczowe momenty sezonu.</p>
                <a class="spotlightLink welcomeButton" href="/archive"><b>Zobacz archiwum eventów</b></a>
            </div>
        </ImageBoxContent>

        </FullImageContainer>
    </Section>

    <Section>
        <div class="faqSection showcasePanel faqPanel">
            <h2>FAQ - serwer Minecraft HEX</h2>
            <FAQ>
                <FAQLine>
                    <FAQQuestion>Jak zapisać się na turniej Minecraft?</FAQQuestion>
                    <FAQAnswer>Większość wydarzeń nie wymaga wcześniejszych zapisów. Dołącz na nasz discord, obserwuj nasz Tiktok, Insta lub YT i śledź ogłoszenia aby być na bierząco.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co dają punkty?</FAQQuestion>
                    <FAQAnswer>Punkty rankingowe pozwalają śledzić postępy graczy, zdobywać nagrody i awansować w rankingach sezonowych oraz rocznych.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co to jest sezon?</FAQQuestion>
                    <FAQAnswer>Sezon to okres, w którym gracze rywalizują o punkty rankingowe. Na koniec sezonu przyznawane są nagrody i aktualizowane rankingi. Terminy sezonów są ustalane przez administrację serwera i będą wyświetlane na stronie oraz ogłaszane na naszym Discordzie.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Kiedy pojawią się kolejne serwery?</FAQQuestion>
                    <FAQAnswer>Informacje o nowych serwerach będą ogłaszane na naszym Discordzie oraz stronie internetowej. Śledź nasze kanały, aby być na bieżąco z nowościami. Planujemy wprowadzać je cyklicznie w kolejnych miesiącach.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Jak grać w różne tryby?</FAQQuestion>
                    <FAQAnswer>Po wejściu na serwer Minecraft, trafiasz do lobby, skąd możesz wybrać interesujący Cię tryb gry przechodząc przez odpowiedni portal.</FAQAnswer>
                </FAQLine>
                <FAQLine>
                    <FAQQuestion>Co muszę zrobić aby dołączyć na serwer?</FAQQuestion>
                    <FAQAnswer>Musisz posiadać Minecraft Java Edition. Zadziała Premium jak i Non-premium. Wymagana wersja gry to 1.21.1. Skopiuj adres serwera i wklej go w Minecraft, aby dołączyć.</FAQAnswer>
                </FAQLine>
            </FAQ>
        </div>
    </Section>



</ContentContainer>
<Footer/>

<script>
    const socialProofGrid = document.querySelector(".socialProofGrid");

    if (socialProofGrid instanceof HTMLElement) {
        const numberElements = socialProofGrid.querySelectorAll("h3");
        const animationDurationMs = 2500;
        let hasAnimated = false;

        const daysElement = socialProofGrid.querySelector("h3[data-days-from]");
        if (daysElement instanceof HTMLElement) {
            const daysFromValue = daysElement.getAttribute("data-days-from");

            if (daysFromValue) {
                const startDate = new Date(`${daysFromValue}T00:00:00`);
                const now = new Date();
                const msPerDay = 1000 * 60 * 60 * 24;
                const daysDiff = Math.floor((now.getTime() - startDate.getTime()) / msPerDay);
                const safeDays = Math.max(0, daysDiff);
                daysElement.textContent = String(safeDays);
            }
        }

        numberElements.forEach((element) => {
            const rawValue = element.textContent ?? "0";
            const parsedValue = Number.parseInt(rawValue.replace(/\D/g, ""), 10);
            const targetValue = Number.isNaN(parsedValue) ? 0 : parsedValue;

            element.setAttribute("data-target", String(targetValue));
            element.textContent = "0";
        });

        const startCountAnimation = () => {
            if (hasAnimated) {
                return;
            }

            hasAnimated = true;
            const animationStart = performance.now();

            const tick = () => {
                const now = performance.now();
                const progress = Math.min((now - animationStart) / animationDurationMs, 1);

                numberElements.forEach((element) => {
                    const targetValue = Number.parseInt(element.getAttribute("data-target") ?? "0", 10);
                    const nextValue = Math.round(targetValue * progress);
                    element.textContent = String(nextValue);
                });

                if (progress < 1) {
                    requestAnimationFrame(tick);
                }
            };

            requestAnimationFrame(tick);
        };

        if ("IntersectionObserver" in window) {
            const counterObserver = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (!entry.isIntersecting) {
                            return;
                        }

                        startCountAnimation();
                        counterObserver.disconnect();
                    });
                },
                { threshold: 0.35 }
            );

            counterObserver.observe(socialProofGrid);
        } else {
            startCountAnimation();
        }
    }

</script>

<style>

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translate(-40px, 200px);
            transform: scale(10);
        }
        to {
            opacity: 1;
            transform: translate(0,0);
            transform: scale(1);
        }
    }

    .bannerHero{
        width: min(900px, 92%);
        margin: 0 auto;
        height: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 18px;
        color: white;
        text-align: center;
        z-index: 1;
        opacity: 0; 
        animation: fadeIn 0.6s ease forwards;
        animation-delay: 1.4s;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.75);
    }

    .bannerTitle {
        margin: 0;
        font-size: clamp(2rem, 3.2vw, 3.15rem);
        line-height: 1.15;
        font-weight: 700;
    }

    .bannerSubtitle {
        margin: 0;
        max-width: 760px;
        font-size: clamp(1.05rem, 1.4vw, 1.35rem);
        line-height: 1.45;
    }

    .bannerCta {
        margin-top: 4px;
    }

    .welcomeButton {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 8px;
        padding: 12px 34px;
        border-radius: 999px;
        background-color: var(--accent-color);
        color: #141414;
        font-size: clamp(1.05rem, 1.2vw, 1.35rem);
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s ease, background-color 0.2s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
        white-space: normal;
        text-align: center;
        line-height: 1.25;
    }

    .welcomeButton b {
        display: block;
        width: 100%;
        text-align: center;
    }

    .welcomeButton:hover {
        background-color: #ffb52a;
        transform: translateY(-2px);
        color: #141414;
        text-decoration: none;
    }

    .welcomeButton:active {
        transform: translateY(0);
    }

    .welcomeButton::after,
    .welcomeButton:hover::after {
        content: none;
        width: 0;
    }

    .seoIntro {
        gap: 8px;
        text-align: center;
    }

    .seoIntro p {
        margin: 0;
        line-height: 1.6;
    }

    .showcasePanel {
        border-radius: 18px;
        padding: 18px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        color: #fff4d8;
        position: relative;
        overflow: hidden;
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.34);
    }

    .showcasePanel::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 10% 0%, rgba(255, 195, 87, 0.2), transparent 42%);
    }

    .stepsPanel,
    .timelinePanel,
    .rewardsPanel,
    .leaderboardPanel,
    .updatesPanel,
    .benefitsPanel,
    .socialProofPanel {
        background: linear-gradient(155deg, #222833 0%, #151920 55%, #10141a 100%);
    }

    .updatesList {
        display: grid;
        gap: 10px;
        position: relative;
        z-index: 1;
    }

    .showcaseCard.updatesItem {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        justify-content: flex-start;
        text-align: left;
        gap: 14px;
        min-width: 0;
        width: 100%;
        max-width: 100%;
        overflow: visible;
    }

    .showcaseCard.updatesItem:nth-child(even) {
        flex-direction: row-reverse;
    }

    .updatesMedia {
        flex: 0 0 34%;
        max-width: 34%;
        min-height: 120px;
        border-radius: 10px;
        border: 1px dashed rgba(255, 255, 255, 0.35);
        background: rgba(0, 0, 0, 0.26);
        color: #f5ddb2;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 10px;
        box-sizing: border-box;
        overflow: hidden;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .updatesContent {
        flex: 1;
        min-width: 0;
        max-width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 6px;
        text-align: center;
        box-sizing: border-box;
        overflow: visible;
    }

    .updatesContent h3,
    .updatesContent p {
        text-align: center;
        width: 100%;
        max-width: 100%;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .benefitsGrid,
    .socialProofGrid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .benefitsGrid .showcaseCard,
    .socialProofItem {
        min-height: 110px;
    }

    .socialProofItem h3 {
        font-size: clamp(1.55rem, 2.1vw, 2rem);
    }

    .showcaseLead {
        margin: 0 0 14px 0;
        text-align: center;
        line-height: 1.6;
        font-size: clamp(1rem, 1.2vw, 1.12rem);
        position: relative;
        z-index: 1;
    }

    .showcaseGrid {
        display: grid;
        gap: 10px;
        position: relative;
        z-index: 1;
    }

    .stepsGrid,
    .timelineGrid,
    .rewardsGrid,
    .leaderboardGrid {
        grid-template-columns: 1fr;
    }

    .showcaseCard {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.42);
        padding: 12px;
        box-sizing: border-box;
    }

    .showcaseCard h3,
    .showcaseCard p {
        margin: 0;
    }

    .showcaseCard h3 {
        color: #ffe39f;
        font-size: clamp(1.03rem, 1.4vw, 1.22rem);
        line-height: 1.3;
    }

    .showcaseCard p {
        color: #f1eadb;
        line-height: 1.5;
    }

    .stepIndex {
        display: inline-flex;
        width: fit-content;
        border-radius: 999px;
        border: 1px solid rgba(255, 224, 160, 0.5);
        color: #ffd88c;
        padding: 2px 9px;
        font-weight: 700;
        font-size: 0.86rem;
    }

    .timelineLabel {
        color: #ffd49c;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.86rem;
        font-weight: 700;
    }

    .rewardStat h3 {
        font-size: clamp(1.12rem, 1.5vw, 1.35rem);
    }

    .rulesInline {
        margin-top: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .rulesInline span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.24);
        background: rgba(0, 0, 0, 0.22);
        color: #ffe4b6;
        padding: 6px 12px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .faqSection {
        padding: 14px 16px;
        color: white;
    }

    .faqPanel {
        background: linear-gradient(155deg, #222833 0%, #151920 55%, #10141a 100%);
    }

    .spotlightSectionTitle {
        margin-bottom: 8px;
        font-size: clamp(1.7rem, 2.6vw, 2.4rem);
        letter-spacing: 0.01em;
    }

    .spotlightCardTitle {
        margin: 0 0 8px 0;
        font-size: clamp(1.5rem, 2.2vw, 2.05rem);
        line-height: 1.2;
    }

    .spotlightCardText {
        margin: 0;
        font-size: clamp(1rem, 1.2vw, 1.15rem);
        line-height: 1.55;
    }

    .spotlightLink {
        margin-top: 8px;
    }

    .spotlightLink b,
    .hogwartLink b {
        font-weight: 700;
    }

    .hogwartTile {
        gap: 10px;
    }

    .hogwartTile,
    .spotlightTile {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    .hogwartShowcase {
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.28);
        background: linear-gradient(155deg, #222833 0%, #151920 55%, #10141a 100%);
        display: grid;
        grid-template-columns: minmax(260px, 42%) 1fr;
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.34);
    }

    .hogwartShowcaseMedia {
        min-height: 420px;
        background-image: url('/images/Welcome/ServerBanner3.png');
        background-size: cover;
        background-position: center;
    }

    .hogwartShowcaseContent {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 18px;
        gap: 10px;
        color: #fff3d2;
        background: linear-gradient(165deg, rgba(9, 10, 14, 0.7), rgba(9, 10, 14, 0.9));
    }

    .hogwartTitle {
        margin: 0;
        font-size: clamp(1.45rem, 2.2vw, 2rem);
        line-height: 1.2;
        overflow-wrap: anywhere;
        word-break: break-word;
        color: #ffe39f;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.65);
    }

    .hogwartLead {
        margin: 0;
        font-size: clamp(1rem, 1.2vw, 1.14rem);
        line-height: 1.55;
        overflow-wrap: anywhere;
        color: #f5efde;
    }

    .hogwartBadges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .hogwartBadges span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.42);
        background: rgba(0, 0, 0, 0.46);
        font-size: 0.92rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        max-width: 100%;
        text-align: center;
        overflow-wrap: anywhere;
        box-sizing: border-box;
        color: #fff1cc;
    }

    .hogwartRelease {
        margin: 0;
        font-size: clamp(0.96rem, 1.1vw, 1.05rem);
        line-height: 1.45;
        overflow-wrap: anywhere;
        color: #f5efde;
    }

    .hogwartLink {
        margin-top: 2px;
    }

    .seoIntro,
    .showcasePanel,
    .faqSection,
    .hogwartShowcase {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: stretch;
        width: 100%;
        align-self: center;
        box-sizing: border-box;
    }

    @media (max-width: 1070px){
        .bannerHero{
            gap: 14px;
            width: min(760px, 94%);
        }
    }

    @media (max-width: 900px){
        .bannerSubtitle {
            max-width: 620px;
        }

    }
    @media (max-width: 980px) {
        .hogwartShowcase {
            grid-template-columns: 1fr;
        }

        .hogwartShowcaseMedia {
            min-height: 260px;
        }
    }

    @media (max-width: 900px){
        .bannerHero{
            justify-content: center;
            padding-bottom: max(60px, env(safe-area-inset-bottom));
            gap: 12px;
        }

        .bannerTitle {
            font-size: clamp(1.5rem, 7vw, 2rem);
        }

        .bannerSubtitle {
            font-size: clamp(0.95rem, 3.5vw, 1.05rem);
