---
interface BreadcrumbItem {
    label: string;
    href?: string;
}

const base = import.meta.env.BASE_URL;
const { items = [] } = Astro.props as { items: BreadcrumbItem[] };

const allItems: BreadcrumbItem[] = [
    { label: "Strona główna", href: base },
    ...items
];
---

<nav class="breadcrumbs" aria-label="Ścieżka nawigacji">
    <ol>
        {allItems.map((item, index) => (
            <li>
                {index < allItems.length - 1 && item.href ? (
                    <a href={item.href}>{item.label}</a>
                ) : (
                    <span aria-current="page">{item.label}</span>
                )}
                {index < allItems.length - 1 && (
                    <span class="breadcrumbSeparator" aria-hidden="true">/</span>
                )}
            </li>
        ))}
    </ol>
</nav>

<style>
    .breadcrumbs {
        width: 100%;
        max-width: 1220px;
        margin: 70px auto 0;
        padding: 10px 16px;
        box-sizing: border-box;
        font-size: 14px;
    }

    .breadcrumbs ol {
        display: flex;
        flex-wrap: wrap;
        list-style: none;
        margin: 0;
        padding: 0;
        gap: 4px;
        align-items: center;
    }

    .breadcrumbs li {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .breadcrumbs a {
        color: var(--accent-color, #ffa600);
        text-decoration: none;
    }

    .breadcrumbs a:hover {
        text-decoration: underline;
    }

    .breadcrumbs span[aria-current="page"] {
        color: #666;
    }

    .breadcrumbSeparator {
        color: #999;
    }
</style>
