---
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';
const ShopComponent = (await import('../components/Shop.astro')).default;

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Sklep HEX Network",
		description: "Sklep serwera Minecraft HEX z usługami cyfrowymi, VIP i dodatkami do rozgrywki.",
		url: absoluteUrl('shop')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak działa zakup w sklepie HEX?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Po wybraniu usługi przechodzisz do płatności przez operatora, a realizacja jest automatycznie przypisywana do konta gracza."
				}
			},
			{
				"@type": "Question",
				name: "Czy zakupione usługi cyfrowe podlegają zwrotowi?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Zakup dotyczy usług cyfrowych i po ich realizacji nie ma możliwości standardowego zwrotu."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Sklep",
				item: absoluteUrl('shop')
			}
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="Sklep HEX Network | VIP, dodatki i wsparcie serwera Minecraft" 
	customDescription="Sklep HEX Network z usługami cyfrowymi do serwera Minecraft: VIP, dodatki quality-of-life i wsparcie organizacji eventów oraz rozwoju projektu."
	canonicalUrl={absoluteUrl('shop')}
	structuredData={structuredData}
>
	<ShopComponent />
</Layout>