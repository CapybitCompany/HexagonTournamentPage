---
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';
const ContactComponent = (await import('../components/Contact.astro')).default;

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "ContactPage",
		name: "Kontakt HEX Network",
		description: "Kontakt do zespołu HEX Network: Discord i e-mail do spraw współpracy i wsparcia.",
		url: absoluteUrl('contact')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak skontaktować się z administracją HEX?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Najłatwiej przez Discord HEX lub mailowo na minecrafthexagon@gmail.com."
				}
			},
			{
				"@type": "Question",
				name: "Gdzie zgłosić współpracę lub reklamę?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Zapytania o współpracę i reklamę przyjmujemy mailowo oraz przez Discord."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Kontakt",
				item: absoluteUrl('contact')
			}
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="Kontakt | HEX Network - Discord, e-mail i współpraca" 
	customDescription="Skontaktuj się z zespołem HEX Network przez Discord lub e-mail. Znajdziesz tu kontakt w sprawie współpracy, wsparcia technicznego i wydarzeń Minecraft."
	canonicalUrl={absoluteUrl('contact')}
	structuredData={structuredData}
>
	<ContactComponent />
</Layout>