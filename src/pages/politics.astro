---
import PoliticsPage from '../components/Politics.astro';
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Polityka prywatności HEX Network",
		description: "Polityka prywatności HEX Network opisująca zasady przetwarzania danych osobowych użytkowników strony, sklepu i serwera Minecraft.",
		url: absoluteUrl('politics')
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Polityka prywatności",
				item: absoluteUrl('politics')
			}
		]
	}
];
---

<Layout 
	customTitle="Polityka prywatności HEX Network | dane osobowe i cookies" 
	customDescription="Sprawdź politykę prywatności HEX Network: zasady przetwarzania danych osobowych, płatności, cookies oraz prawa użytkowników strony i serwera Minecraft."
	canonicalUrl={absoluteUrl('politics')}
	structuredData={structuredData}
>
	<PoliticsPage />
</Layout>