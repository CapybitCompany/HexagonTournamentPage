---
import HexParkourPage from '../components/PageContent/ServerArticles/HexParkour.astro';
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX Parkour",
		description: "Strona trybu HEX Parkour z informacjami o trasach, rekordach czasu i rankingach sezonowych.",
		url: absoluteUrl('hexParkour')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak działa ranking czasu na Parkour?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Każda trasa ma oddzielną tabelę wyników, a ranking aktualizuje się po ukończeniu biegu."
				}
			},
			{
				"@type": "Question",
				name: "Czy będą trasy dla początkujących?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Tak, planujemy poziomy trudności od tras treningowych po wymagające challenge."
				}
			},
			{
				"@type": "Question",
				name: "Jak często pojawiają się nowe mapy Parkour?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Nowe mapy będą dodawane sezonowo wraz z resetem tabel i wydarzeniami specjalnymi."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Parkour",
				item: absoluteUrl('hexParkour')
			}
		]
	}
];
---

<Layout
	customTitle="HEX Parkour - serwer Minecraft w przygotowaniu"
	customDescription="HEX Parkour - nowy serwer Minecraft z trasami parkour i rankingami. Wkrótce więcej informacji."
	canonicalUrl={absoluteUrl('hexParkour')}
	structuredData={structuredData}
>
	<HexParkourPage />
</Layout>
