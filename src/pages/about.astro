---
import AboutPage from '../components/About.astro';
import Layout from '../layouts/Layout.astro';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "AboutPage",
		name: "O nas - HEX Network",
		description: 'Poznaj HEX Network - polską społeczność i serwer Minecraft tworzącą turnieje, eventy, rankingi oraz autorskie tryby rozgrywki.',
		url: "https://www.minecrafthex.pl/about/"
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: 'Czym jest HEX Network?',
				acceptedAnswer: {
					"@type": "Answer",
					text: 'HEX Network to polska społeczność i serwer Minecraft łączące turnieje, eventy, ranking graczy oraz autorskie tryby rozgrywki.',
				}
			},
			{
				"@type": "Question",
				name: 'Gdzie publikowane są informacje o eventach i turniejach?',
				acceptedAnswer: {
					"@type": "Answer",
					text: 'Najważniejsze informacje publikujemy na stronie głównej, Discordzie HEX Network oraz w archiwum wydarzeń.',
				},
			},
			{
				'@type': 'Question',
				name: 'Jak mogę dołączyć do społeczności HEX?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Najłatwiej zacząć od dołączenia na Discord HEX Network, gdzie znajdują się ogłoszenia, informacje o serwerze i najbliższych wydarzeniach.',
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: "https://www.minecrafthex.pl/"
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "O nas",
				item: "https://www.minecrafthex.pl/about/"
			}
		]
	}
];

---

<Layout 
	customTitle="O nas | HEX Network - polska społeczność i serwer Minecraft"
	customDescription="Poznaj HEX Network - polską społeczność i serwer Minecraft z turniejami, eventami, rankingiem graczy i autorskimi trybami. Sprawdź, jak działa projekt i gdzie dołączyć."
	ogImage="/images/About/aboutBanner.webp"
	ogType="article"
	canonicalUrl="https://www.minecrafthex.pl/about"
	structuredData={structuredData}
>
	<AboutPage />
</Layout>
