---
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';
const ArchiveComponent = (await import('../components/Archive.astro')).default;

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "CollectionPage",
		name: "Archiwum wydarzeń HEX",
		description: "Archiwum turniejów i eventów Minecraft HEX z nagrodami, datami i relacjami.",
		url: absoluteUrl('archive')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Gdzie sprawdzić wyniki poprzednich turniejów HEX?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Wyniki, daty i informacje o nagrodach znajdziesz w archiwum wydarzeń na stronie HEX."
				}
			},
			{
				"@type": "Question",
				name: "Jak często aktualizowane jest archiwum eventów?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Archiwum aktualizujemy po zakończeniu każdej edycji turnieju i większych wydarzeń."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Archiwum",
				item: absoluteUrl('archive')
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "ItemList",
		name: "Archiwum edycji HEX",
		itemListOrder: "https://schema.org/ItemListOrderDescending",
		numberOfItems: 6,
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "HEX I", url: absoluteUrl('archive#hex1') },
			{ "@type": "ListItem", position: 2, name: "HEX II", url: absoluteUrl('archive#hex2') },
			{ "@type": "ListItem", position: 3, name: "HEX III", url: absoluteUrl('archive#hex3') },
			{ "@type": "ListItem", position: 4, name: "HEX IV", url: absoluteUrl('archive#hex4') },
			{ "@type": "ListItem", position: 5, name: "HEX V", url: absoluteUrl('archive#hex5') },
			{ "@type": "ListItem", position: 6, name: "HEX VI", url: absoluteUrl('archive#hex6') }
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="Archiwum wydarzeń - turnieje i eventy Minecraft HEX" 
	customDescription="Archiwum wydarzeń Minecraft HEX - opisy turniejów i eventów, liczba uczestników, nagrody oraz galerie zdjęć z dotychczasowych edycji."
	canonicalUrl={absoluteUrl('archive')}
	keywords="archiwum minecraft, historia turniejów minecraft, HEX I, HEX II, HEX III, HEX IV, HEX V, HEX VI, eventy minecraft, wyniki turniejów"
	structuredData={structuredData}
>
	<ArchiveComponent />
</Layout>