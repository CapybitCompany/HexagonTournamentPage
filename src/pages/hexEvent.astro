---
import HexEventPage from '../components/PageContent/ServerArticles/HexEvent.astro';
import Layout from '../layouts/Layout.astro';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX Event Zone",
		description: "Strona trybu HEX Event Zone z informacjami o turniejach, zapisach i harmonogramach wydarzeń Minecraft.",
		url: "https://www.minecrafthex.pl/hexEvent/"
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak zapisać się na turniej Event Zone?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Zapisy publikujemy na stronie i na Discordzie HEX przed każdą edycją wydarzenia."
				}
			},
			{
				"@type": "Question",
				name: "Kiedy ruszają pierwsze eventy?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Najbliższy turniej zaplanowany jest na 4.04.2026 o 19:00, a kolejne terminy będą ogłaszane cyklicznie."
				}
			},
			{
				"@type": "Question",
				name: "Gdzie sprawdzić wyniki poprzednich eventów?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Wyniki i relacje trafiają do archiwum eventów oraz komunikatów na Discordzie."
				}
			},
			{
				"@type": "Question",
				name: "Czym jest Tytanic?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Tytanic to nadchodzący event HEX. Szczegóły i zasady zostaną ogłoszone wkrótce na Discordzie i stronie."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: "https://www.minecrafthex.pl/"
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Event Zone",
				item: "https://www.minecrafthex.pl/hexEvent/"
			}
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="HEX Event Zone - turnieje i eventy Minecraft" 
	customDescription="HEX Event Zone - turnieje, wyzwania i rywalizacja w Minecraft. Nadchodzący event: Tytanic. Sprawdź szczegóły, zapisy i archiwum."
	canonicalUrl="https://www.minecrafthex.pl/hexEvent"
	structuredData={structuredData}
>
	<HexEventPage />
</Layout>