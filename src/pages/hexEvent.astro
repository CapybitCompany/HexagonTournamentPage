---
import HexEventPage from '../components/PageContent/ServerArticles/HexEvent.astro';
import Layout from '../layouts/Layout.astro';
import { nextHexEvent } from '../data/hex-network';
import { absoluteUrl } from '../utils/urls';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX Event Zone",
		description: "Strona trybu HEX Event Zone z informacjami o turniejach, zapisach i harmonogramach wydarzeń Minecraft.",
		url: absoluteUrl('hexEvent')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak zapisać się na turniej Event Zone?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Zapisy publikujemy na stronie i na Discordzie HEX przed każdą edycją wydarzenia."
				}
			},
			{
				"@type": "Question",
				name: "Kiedy ruszają pierwsze eventy?",
				acceptedAnswer: {
					"@type": "Answer",
					text: `Najbliższy turniej zaplanowany jest na ${nextHexEvent.displayDateTime}, a kolejne terminy będą ogłaszane cyklicznie.`
				}
			},
			{
				"@type": "Question",
				name: "Gdzie sprawdzić wyniki poprzednich eventów?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Wyniki i relacje trafiają do archiwum eventów oraz komunikatów na Discordzie."
				}
			},
			{
				"@type": "Question",
				name: "Czym jest Titanic?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Titanic to nadchodzący event HEX. Szczegóły i zasady zostaną ogłoszone wkrótce na Discordzie i stronie."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Event Zone",
				item: absoluteUrl('hexEvent')
			}
		]
	}
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout 
	customTitle="HEX Event Zone - turnieje i eventy Minecraft" 
	customDescription={`HEX Event Zone - turnieje, wyzwania i rywalizacja w Minecraft. Nadchodzący event: ${nextHexEvent.theme}. Sprawdź szczegóły, zapisy i archiwum.`}
	keywords="event zone minecraft, turniej minecraft, HEX event, zapisy turniej, minecraft rywalizacja"
	canonicalUrl={absoluteUrl('hexEvent')}
	structuredData={structuredData}
>
	<HexEventPage />
</Layout>