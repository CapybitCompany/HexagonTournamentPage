---
import DevlogPage from '../components/PageContent/Devlog/Devlog.astro';
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Devlog HEX SMP",
		description: "Dziennik produkcji trybu HEX SMP — śledź postępy budowy nowego trybu Minecraft na serwerze HEX.",
		url: absoluteUrl('devlog')
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Devlog",
				item: absoluteUrl('devlog')
			}
		]
	}
];
---

<Layout
	customTitle="Devlog HEX SMP - dziennik produkcji nowego trybu Minecraft"
	customDescription="Dziennik produkcji HEX SMP. Śledź postępy budowy nowego trybu Minecraft na serwerze HEX — mechaniki, mapa, balans i więcej."
	canonicalUrl={absoluteUrl('devlog')}
	structuredData={structuredData}
>
	<DevlogPage />
</Layout>
