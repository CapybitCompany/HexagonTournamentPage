---
import HexPvpPage from '../components/PageContent/ServerArticles/HexPvp.astro';
import Layout from '../layouts/Layout.astro';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX PVP",
		description: "Strona trybu HEX PVP z informacjami o arenach, balansie i rankingach graczy na serwerze Minecraft.",
		url: "https://www.minecrafthex.pl/hexPvp/"
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Czy na serwerze PVP będą tryby 1v1 i team?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Tak, planujemy areny 1v1 oraz formaty drużynowe z osobnymi tabelami wyników."
				}
			},
			{
				"@type": "Question",
				name: "Jak działa ranking PVP?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Ranking będzie oparty o zwycięstwa, serie wygranych i aktywność w sezonie."
				}
			},
			{
				"@type": "Question",
				name: "Gdzie zgłaszać uwagi do balansu?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Feedback i propozycje zmian balansu zbieramy na Discordzie HEX."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: "https://www.minecrafthex.pl/"
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "PVP",
				item: "https://www.minecrafthex.pl/hexPvp/"
			}
		]
	}
];
---

<Layout
	customTitle="HEX PVP - serwer Minecraft w przygotowaniu"
	customDescription="HEX PVP - nowy serwer Minecraft z arenami i rankingiem graczy. Wkrótce więcej informacji."
	canonicalUrl="https://www.minecrafthex.pl/hexPvp"
	structuredData={structuredData}
>
	<HexPvpPage />
</Layout>
