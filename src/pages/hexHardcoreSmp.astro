---
import HexHardcoreSmpPage from '../components/PageContent/ServerArticles/HexHardcoreSmp.astro';
import Layout from '../layouts/Layout.astro';
import { absoluteUrl } from '../utils/urls';

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "HEX Hardcore SMP",
		description: "Strona trybu HEX Hardcore SMP z zasadami śmierci, banów czasowych, rang i Heart Fragmentów.",
		url: absoluteUrl('hexHardcoreSmp')
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "Jak naliczany jest ban po śmierci?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Ban rośnie wraz z czasem przeżycia i liczbą zabójstw, zgodnie z zasadami trybu Hardcore SMP."
				}
			},
			{
				"@type": "Question",
				name: "Do czego służą Heart Fragmenty?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Heart Fragmenty skracają czas bana po śmierci i pomagają szybciej wrócić do gry."
				}
			},
			{
				"@type": "Question",
				name: "Gdzie śledzić ogłoszenia dla Hardcore SMP?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Najważniejsze komunikaty i zapisy publikujemy na Discordzie HEX oraz stronie głównej."
				}
			}
		]
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Strona główna",
				item: absoluteUrl()
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Hardcore SMP",
				item: absoluteUrl('hexHardcoreSmp')
			}
		]
	}
];
---

<Layout
	customTitle="HEX Hardcore SMP - serwer Minecraft w przygotowaniu"
	customDescription="HEX Hardcore SMP - nowy serwer Minecraft z zasadami HEX i systemem tymczasowych banów zależnych od statystyk."
	canonicalUrl={absoluteUrl('hexHardcoreSmp')}
	structuredData={structuredData}
>
	<HexHardcoreSmpPage />
</Layout>
